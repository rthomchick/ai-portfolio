  }

  .starter-btn:last-child {
    margin-bottom: 0;
  }

  .starter-btn:hover {
    background: #f0fdf9;
    border-color: #99f6e4;
    color: #0f766e;
  }

  .dark .starter-btn {
    color: #d6d3d1;
    background: #292524;
    border-color: #44403c;
  }

  .dark .starter-btn:hover {
    background: #1c2523;
    border-color: #0d9488;
    color: #2dd4bf;
  }

  #ask-conversation {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 12px;
  }

  .ask-q-bubble {
    align-self: flex-end;
    background: #0f766e;
    color: #ffffff;
    font-size: 13px;
    line-height: 1.5;
    border-radius: 12px 12px 2px 12px;
    padding: 8px 12px;
    max-width: 80%;
  }

  .dark .ask-q-bubble {
    background: #0d9488;
  }

  .ask-answer {
    align-self: flex-start;
    max-width: 100%;
  }

  .ask-answer-body {
    font-size: 14px;
    line-height: 1.65;
    color: #57534e;
  }

  .dark .ask-answer-body {
    color: #a8a29e;
  }

  .ask-answer-text {
    white-space: pre-wrap;
