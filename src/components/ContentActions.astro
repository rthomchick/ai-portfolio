---
interface KeyPoint {
  title: string;
  headingId: string;
}

interface Summary {
  overview: string;
  keyPoints: KeyPoint[];
}

interface Props {
  slug: string;
  summary: Summary | null;
  hasAudio?: boolean;
}

const { slug, summary, hasAudio = false } = Astro.props;
const hasSummary = summary !== null;
---

<div class="content-actions">
  <div class="content-actions-left">
    <button
      id="summary-btn"
      class={`ca-btn${hasSummary ? '' : ' ca-disabled'}`}
      aria-label="AI summary"
      disabled={!hasSummary}
    >
      Summarize <i class="ti ti-sparkles" aria-hidden="true"></i>
    </button>
    <button
      id="listen-btn"
      class={`ca-btn${hasAudio ? '' : ' ca-disabled'}`}
      aria-label="Listen to this entry"
      disabled={!hasAudio}
    >
      Listen <i class="ti ti-headphones" aria-hidden="true"></i>
    </button>
    <button class="ca-btn ca-disabled" aria-label="Ask AI about this entry" disabled>
      Ask AI <i class="ti ti-message-question" aria-hidden="true"></i>
    </button>
  </div>
  <div class="content-actions-right">
    <button id="share-btn" class="ca-btn" aria-label="Share">
      Share <i class="ti ti-upload" aria-hidden="true"></i>
    </button>
    <div id="share-dropdown" class="share-dropdown hidden">
      <button class="share-item" data-action="copy">
        <i class="ti ti-link" aria-hidden="true"></i> Copy link
      </button>
      <div class="share-sep"></div>
      <a class="share-item" data-action="linkedin" target="_blank" rel="noopener noreferrer">
        <i class="ti ti-brand-linkedin" aria-hidden="true"></i> Share on LinkedIn
      </a>
      <a class="share-item" data-action="x" target="_blank" rel="noopener noreferrer">
        <i class="ti ti-brand-x" aria-hidden="true"></i> Share on X
      </a>
      <a class="share-item" data-action="bluesky" target="_blank" rel="noopener noreferrer">
        <i class="ti ti-brand-bluesky" aria-hidden="true"></i> Share on Bluesky
      </a>
    </div>
  </div>
</div>

<div id="summary-panel" class="summary-panel hidden"></div>

<!-- Listen panel: slug passed via data attribute so the client script can construct the audio URL -->
<div
  id="listen-panel"
  class="listen-panel hidden"
  data-slug={slug}
></div>

{hasSummary && (
  <script id="summary-data" type="application/json" set:html={JSON.stringify(summary)} />
)}

<style is:global>
  .content-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 0;
    margin-bottom: 24px;
    border-top: 1px solid #e7e5e4;
    border-bottom: 1px solid #e7e5e4;
  }

  .dark .content-actions {
    border-top-color: #292524;
    border-bottom-color: #292524;
  }

  .content-actions-left {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .content-actions-right {
    position: relative;
  }

  .ca-btn {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 13px;
    font-family: 'DM Sans', sans-serif;
    color: #78716c;
    background: none;
    border: none;
    border-radius: 6px;
    padding: 6px 10px;
    cursor: pointer;
    transition: all 150ms ease;
  }

  .ca-btn:hover,
  .ca-btn:focus-visible {
    background: #f5f5f4;
    color: #1c1917;
  }

  .dark .ca-btn:hover,
  .dark .ca-btn:focus-visible {
    background: #1c1917;
    color: #f5f5f4;
  }

  .ca-btn.ca-disabled,
  .ca-btn:disabled {
    opacity: 0.35;
    pointer-events: none;
  }

  /* Share dropdown */
  .share-dropdown {
    position: absolute;
    right: 0;
    top: calc(100% + 8px);
    background: #ffffff;
    border: 1px solid #e7e5e4;
    border-radius: 12px;
    padding: 6px;
    min-width: 188px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08), 0 1px 4px rgba(0, 0, 0, 0.04);
    z-index: 50;
  }

  .dark .share-dropdown {
    background: #1c1917;
    border-color: #292524;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.35);
  }

  .share-item {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    padding: 8px 10px;
    font-size: 13px;
    font-weight: 500;
    font-family: inherit;
    color: #44403c;
    background: transparent;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    transition: background 120ms, color 120ms;
    text-align: left;
    white-space: nowrap;
  }

  .share-item:hover {
    background: #f5f5f4;
    color: #0f766e;
  }

  .dark .share-item {
    color: #d6d3d1;
  }

  .dark .share-item:hover {
    background: #292524;
    color: #2dd4bf;
  }

  .share-sep {
    height: 1px;
    background: #e7e5e4;
    margin: 4px 6px;
  }

  .dark .share-sep {
    background: #292524;
  }

  /* Summary panel */
  .summary-panel {
    border: 1px solid #e7e5e4;
    border-radius: 12px;
    padding: 20px 24px;
    margin-bottom: 28px;
    background: #fafaf9;
  }

  .dark .summary-panel {
    background: #1c1917;
    border-color: #292524;
  }

  .summary-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }

  .summary-chip {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #0f766e;
    background: #ccfbf1;
    padding: 3px 8px;
    border-radius: 9999px;
  }

  .dark .summary-chip {
    color: #2dd4bf;
    background: rgba(45, 212, 191, 0.12);
  }

  .summary-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 6px;
    border: none;
    background: transparent;
    color: #a8a29e;
    cursor: pointer;
    font-size: 16px;
    transition: background 120ms, color 120ms;
    padding: 0;
  }

  .summary-close:hover {
    background: #e7e5e4;
    color: #57534e;
  }

  .dark .summary-close {
    color: #78716c;
  }

  .dark .summary-close:hover {
    background: #292524;
    color: #d6d3d1;
  }

  .summary-text {
    font-size: 14px;
    line-height: 1.65;
    color: #57534e;
    margin: 0 0 16px;
    padding-left: 12px;
  }

  .dark .summary-text {
    color: #a8a29e;
  }

  /* Blinking cursor during streaming */
  .ca-streaming::after {
    content: '▋';
    color: #0f766e;
    animation: ca-blink 500ms step-end infinite;
    margin-left: 1px;
  }

  .dark .ca-streaming::after {
    color: #2dd4bf;
  }

  @keyframes ca-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  .summary-takeaways-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #a8a29e;
    margin-bottom: 4px;
    padding: 0 12px;
  }

  .summary-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border-radius: 6px;
    cursor: pointer;
    transition: background 120ms ease;
    text-decoration: none;
  }

  .summary-link:hover {
    background: #ffffff;
  }

  .dark .summary-link:hover {
    background: #292524;
  }

  .summary-link-title {
    font-size: 13px;
    font-weight: 500;
    color: #0F6E56;
  }

  .dark .summary-link-title {
    color: #2dd4bf;
  }

  /* ── Listen panel ──────────────────────────────────────────────────────── */
  .listen-panel {
    border: 1px solid #e7e5e4;
    border-radius: 12px;
    padding: 16px 20px;
    margin-bottom: 28px;
    background: #fafaf9;
  }

  .dark .listen-panel {
    background: #1c1917;
    border-color: #292524;
  }

  .listen-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }

  .listen-chip {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #0f766e;
    background: #ccfbf1;
    padding: 3px 8px;
    border-radius: 9999px;
  }

  .dark .listen-chip {
    color: #2dd4bf;
    background: rgba(45, 212, 191, 0.12);
  }

  /* Reuse .summary-close styles — identical close button pattern */

  .listen-controls {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .listen-play-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: none;
    background: #0f766e;
    color: #ffffff;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 150ms ease, transform 100ms ease;
    padding: 0;
    font-size: 14px;
  }

  .listen-play-btn:hover {
    background: #0d6460;
    transform: scale(1.05);
  }

  .listen-play-btn:active {
    transform: scale(0.97);
  }

  .dark .listen-play-btn {
    background: #0d9488;
  }

  .dark .listen-play-btn:hover {
    background: #0f766e;
  }

  /* Play icon nudge for optical centering */
  .listen-play-btn .ti-player-play {
    margin-left: 2px;
  }

  .listen-progress-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  .listen-progress-bar {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 3px;
    border-radius: 9999px;
    background: #e7e5e4;
    cursor: pointer;
    outline: none;
  }

  .dark .listen-progress-bar {
    background: #44403c;
  }

  /* Webkit fill */
  .listen-progress-bar::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #0f766e;
    cursor: pointer;
    margin-top: -4.5px;
    transition: transform 120ms ease;
  }

  .listen-progress-bar::-webkit-slider-thumb:hover {
    transform: scale(1.3);
  }

  .listen-progress-bar::-webkit-slider-runnable-track {
    height: 3px;
    border-radius: 9999px;
  }

  /* Firefox */
  .listen-progress-bar::-moz-range-thumb {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #0f766e;
    border: none;
    cursor: pointer;
  }

  .listen-progress-bar::-moz-range-track {
    height: 3px;
    background: #e7e5e4;
    border-radius: 9999px;
  }

  .dark .listen-progress-bar::-moz-range-track {
    background: #44403c;
  }

  .listen-time {
    font-size: 11px;
    color: #a8a29e;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
    align-self: flex-end;
  }

  .listen-error {
    font-size: 13px;
    color: #a8a29e;
    padding: 4px 0;
  }

  /* Mobile: icons-only adjusts ca-btn, player stays full-width */
  @media (max-width: 639px) {
    .ca-btn {
      font-size: 0;
      padding: 8px;
      gap: 0;
    }

    .ca-btn i {
      font-size: 19px;
    }
  }
</style>

<script>
  // ── Share ──────────────────────────────────────────────────────────────────
  const shareBtn = document.getElementById('share-btn');
  const shareDropdown = document.getElementById('share-dropdown');

  const pageUrl = window.location.href;
  const pageTitle = document.title.replace(/\s*—.*$/, '').trim();

  // Populate share links
  const linkedinLink = shareDropdown?.querySelector('[data-action="linkedin"]') as HTMLAnchorElement | null;
  const xLink = shareDropdown?.querySelector('[data-action="x"]') as HTMLAnchorElement | null;
  const blueskyLink = shareDropdown?.querySelector('[data-action="bluesky"]') as HTMLAnchorElement | null;

  if (linkedinLink) linkedinLink.href = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`;
  if (xLink) xLink.href = `https://twitter.com/intent/tweet?url=${encodeURIComponent(pageUrl)}&text=${encodeURIComponent(pageTitle)}`;
  if (blueskyLink) blueskyLink.href = `https://bsky.app/intent/compose?text=${encodeURIComponent(pageTitle + ' ' + pageUrl)}`;

  shareBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    shareDropdown?.classList.toggle('hidden');
  });

  shareDropdown?.querySelector('[data-action="copy"]')?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(pageUrl);
      const copyBtn = shareDropdown?.querySelector('[data-action="copy"]');
      if (copyBtn) {
        const original = copyBtn.innerHTML;
        copyBtn.innerHTML = '<i class="ti ti-check" aria-hidden="true"></i> Copied!';
        setTimeout(() => { copyBtn.innerHTML = original; }, 2000);
      }
    } catch {
      // clipboard not available
    }
    shareDropdown?.classList.add('hidden');
  });

  document.addEventListener('click', (e) => {
    if (!shareDropdown?.classList.contains('hidden')) {
      if (!shareBtn?.contains(e.target as Node) && !shareDropdown?.contains(e.target as Node)) {
        shareDropdown?.classList.add('hidden');
      }
    }
  });

  // ── Summary ────────────────────────────────────────────────────────────────
  const summaryBtn = document.getElementById('summary-btn');
  const summaryPanel = document.getElementById('summary-panel');
  const summaryDataEl = document.getElementById('summary-data');

  if (summaryDataEl && summaryPanel && summaryBtn) {
    const summary = JSON.parse(summaryDataEl.textContent || '{}');
    let rendered = false;

    summaryBtn.addEventListener('click', () => {
      if (!summaryPanel.classList.contains('hidden')) {
        summaryPanel.classList.add('hidden');
        return;
      }

      summaryPanel.classList.remove('hidden');

      if (!rendered) {
        const keyPointsHtml = summary.keyPoints.map((point: { headingId: string; title: string }) => `
          <a class="summary-link" data-target="${point.headingId}" style="opacity:0;transform:translateY(5px)">
            <i class="ti ti-arrow-right" style="color:#0F6E56;font-size:14px;margin-top:1px;flex-shrink:0;" aria-hidden="true"></i>
            <span class="summary-link-title">${point.title}</span>
          </a>
        `).join('');

        summaryPanel.innerHTML = `
          <div class="summary-header">
            <span class="summary-chip">AI summary</span>
            <button class="summary-close" id="summary-close" aria-label="Close summary"><i class="ti ti-x" aria-hidden="true"></i></button>
          </div>
          <p class="summary-text"></p>
          <div class="summary-takeaways-label" style="opacity:0">Key takeaways</div>
          <div>${keyPointsHtml}</div>
        `;

        rendered = true;

        // Wire interactions
        summaryPanel.querySelectorAll<HTMLElement>('.summary-link').forEach(link => {
          link.addEventListener('click', () => {
            const targetId = link.dataset.target;
            if (targetId) {
              document.getElementById(targetId)?.scrollIntoView({ behavior: 'smooth' });
            }
          });
          link.addEventListener('keydown', (e: KeyboardEvent) => {
            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); link.click(); }
          });
        });
        document.getElementById('summary-close')?.addEventListener('click', () => {
          summaryPanel.classList.add('hidden');
        });

        // ── Streaming animation ────────────────────────────────────────────
        const overviewEl = summaryPanel.querySelector<HTMLElement>('.summary-text');
        const labelEl = summaryPanel.querySelector<HTMLElement>('.summary-takeaways-label');
        const linkEls = summaryPanel.querySelectorAll<HTMLElement>('.summary-link');
        const text = summary.overview as string;

        if (!overviewEl) return;

        overviewEl.classList.add('ca-streaming');

        // Stream overview using rAF — time-based so it's immune to timer throttling
        const STREAM_MS = 1100;
        const startTime = performance.now();

        function streamFrame(now: number) {
          const progress = Math.min((now - startTime) / STREAM_MS, 1);
          const chars = Math.floor(progress * text.length);
          overviewEl!.textContent = text.slice(0, chars);

          if (progress < 1) {
            requestAnimationFrame(streamFrame);
          } else {
            overviewEl!.textContent = text;
            overviewEl!.classList.remove('ca-streaming');
            setTimeout(() => {
              if (labelEl) {
                labelEl.style.transition = 'opacity 180ms ease';
                labelEl.style.opacity = '1';
              }
              linkEls.forEach((el, idx) => {
                setTimeout(() => {
                  el.style.transition = 'opacity 200ms ease, transform 200ms ease';
                  el.style.opacity = '1';
                  el.style.transform = 'translateY(0)';
                }, idx * 70);
              });
            }, 80);
          }
        }
        requestAnimationFrame(streamFrame);
      }
    });
  }

  // ── Listen (Web Speech API — v0) ───────────────────────────────────────────
  const listenBtn = document.getElementById('listen-btn');
  const listenPanel = document.getElementById('listen-panel');

  if (listenBtn && listenPanel && 'speechSynthesis' in window) {
    let utterance: SpeechSynthesisUtterance | null = null;
    let isPlaying = false;
    let rendered = false;

    // Extract readable text from the article body.
    // Targets the prose container; falls back to <main> if the selector misses.
    function getArticleText(): string {
      const prose = document.querySelector<HTMLElement>('.prose, article, main');
      if (!prose) return document.body.innerText;

      // Clone so we can strip elements without affecting the DOM
      const clone = prose.cloneNode(true) as HTMLElement;

      // Remove elements that shouldn't be read aloud
      clone.querySelectorAll(
        'pre, code, .content-actions, .summary-panel, .listen-panel, nav, footer, script, style'
      ).forEach(el => el.remove());

      // Collapse excessive whitespace
      return clone.innerText.replace(/\n{3,}/g, '\n\n').trim();
    }

    function formatTime(seconds: number): string {
      const m = Math.floor(seconds / 60);
      const s = Math.floor(seconds % 60);
      return `${m}:${s.toString().padStart(2, '0')}`;
    }

    // Rough word-count-based duration estimate (avg 150 wpm for TTS)
    function estimateDuration(text: string): number {
      return Math.ceil(text.split(/\s+/).length / 150) * 60;
    }

    function buildPanel() {
      listenPanel.innerHTML = `
        <div class="listen-header">
          <span class="listen-chip">Listen</span>
          <button class="summary-close" id="listen-close" aria-label="Close player">
            <i class="ti ti-x" aria-hidden="true"></i>
          </button>
        </div>
        <div class="listen-controls">
          <button class="listen-play-btn" id="listen-play" aria-label="Play">
            <i class="ti ti-player-play" aria-hidden="true"></i>
          </button>
          <div class="listen-progress-wrap">
            <input
              type="range"
              class="listen-progress-bar"
              id="listen-progress"
              min="0"
              max="100"
              value="0"
              step="0.1"
              aria-label="Playback position"
            />
            <span class="listen-time" id="listen-time">0:00</span>
          </div>
        </div>
      `;
      rendered = true;

      const playBtn = document.getElementById('listen-play')!;
      const progressBar = document.getElementById('listen-progress') as HTMLInputElement;
      const timeEl = document.getElementById('listen-time')!;
      const closeBtn = document.getElementById('listen-close')!;

      const articleText = getArticleText();
      const estimatedDuration = estimateDuration(articleText);

      // speechSynthesis doesn't expose real-time position, so we simulate progress
      // using a rAF timer that tracks elapsed wall-clock time vs estimated duration.
      let rafId: number | null = null;
      let startedAt: number | null = null;
      let pausedElapsed = 0; // seconds elapsed before current pause

      function startProgressTimer() {
        startedAt = performance.now();
        function tick() {
          if (!isPlaying) return;
          const elapsed = pausedElapsed + (performance.now() - startedAt!) / 1000;
          const clamped = Math.min(elapsed, estimatedDuration);
          const pct = (clamped / estimatedDuration) * 100;

          progressBar.value = String(pct);
          progressBar.style.setProperty('--pct', `${pct}%`);
          timeEl.textContent = formatTime(clamped);

          if (clamped < estimatedDuration) {
            rafId = requestAnimationFrame(tick);
          }
        }
        rafId = requestAnimationFrame(tick);
      }

      function stopProgressTimer() {
        if (rafId !== null) {
          cancelAnimationFrame(rafId);
          rafId = null;
        }
        if (startedAt !== null) {
          pausedElapsed += (performance.now() - startedAt) / 1000;
          startedAt = null;
        }
      }

      function setPlayIcon() {
        playBtn.innerHTML = '<i class="ti ti-player-play" style="margin-left:2px" aria-hidden="true"></i>';
        playBtn.setAttribute('aria-label', 'Play');
      }

      function setPauseIcon() {
        playBtn.innerHTML = '<i class="ti ti-player-pause" aria-hidden="true"></i>';
        playBtn.setAttribute('aria-label', 'Pause');
      }

      function resetState() {
        stopProgressTimer();
        pausedElapsed = 0;
        progressBar.value = '0';
        progressBar.style.setProperty('--pct', '0%');
        timeEl.textContent = '0:00';
        setPlayIcon();
        isPlaying = false;
        utterance = null;
      }

      playBtn.addEventListener('click', () => {
        if (isPlaying) {
          // Pause
          window.speechSynthesis.pause();
          stopProgressTimer();
          isPlaying = false;
          setPlayIcon();
        } else if (window.speechSynthesis.paused && utterance) {
          // Resume
          window.speechSynthesis.resume();
          isPlaying = true;
          setPauseIcon();
          startProgressTimer();
        } else {
          // Fresh start (or restart after completion)
          window.speechSynthesis.cancel();
          pausedElapsed = 0;

          utterance = new SpeechSynthesisUtterance(articleText);
          utterance.rate = 0.95; // Slightly slower than default — more comfortable for long reads
          utterance.lang = 'en-US';

          utterance.onstart = () => {
            isPlaying = true;
            setPauseIcon();
            startProgressTimer();
          };

          utterance.onend = () => {
            resetState();
          };

          utterance.onerror = (e) => {
            // 'interrupted' fires on cancel() — not a real error
            if (e.error === 'interrupted') return;
            resetState();
            listenPanel.innerHTML += `<p class="listen-error">Playback error: ${e.error}</p>`;
          };

          window.speechSynthesis.speak(utterance);
        }
      });

      // Progress bar scrub: Web Speech API doesn't support seeking,
      // so we restart from the approximate character position.
      progressBar.addEventListener('input', () => {
        const pct = parseFloat(progressBar.value) / 100;
        const charOffset = Math.floor(pct * articleText.length);
        const remainingText = articleText.slice(charOffset);

        window.speechSynthesis.cancel();
        stopProgressTimer();

        pausedElapsed = pct * estimatedDuration;
        progressBar.style.setProperty('--pct', `${pct * 100}%`);
        timeEl.textContent = formatTime(pausedElapsed);

        utterance = new SpeechSynthesisUtterance(remainingText);
        utterance.rate = 0.95;
        utterance.lang = 'en-US';

        utterance.onstart = () => {
          isPlaying = true;
          setPauseIcon();
          startProgressTimer();
        };

        utterance.onend = () => {
          resetState();
        };

        utterance.onerror = (e) => {
          if (e.error === 'interrupted') return;
          resetState();
        };

        window.speechSynthesis.speak(utterance);
      });

      closeBtn.addEventListener('click', () => {
        window.speechSynthesis.cancel();
        resetState();
        listenPanel.classList.add('hidden');
      });

      // Guard against Chrome's 15s utterance bug:
      // Chrome silently stops speaking long utterances unless you call getVoices()
      // and pause/resume periodically. The workaround: resume every 10s.
      setInterval(() => {
        if (isPlaying && window.speechSynthesis.speaking && !window.speechSynthesis.paused) {
          window.speechSynthesis.pause();
          window.speechSynthesis.resume();
        }
      }, 10000);
    }

    listenBtn.addEventListener('click', () => {
      // Close summary if open — only one panel at a time
      summaryPanel?.classList.add('hidden');

      if (!listenPanel.classList.contains('hidden')) {
        window.speechSynthesis.cancel();
        listenPanel.classList.add('hidden');
        return;
      }

      listenPanel.classList.remove('hidden');
      if (!rendered) buildPanel();
    });

    // Stop speech if user navigates away (SPA nav or page unload)
    window.addEventListener('beforeunload', () => {
      window.speechSynthesis.cancel();
    });
  }
</script>
