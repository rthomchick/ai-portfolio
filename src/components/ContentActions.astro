---
interface KeyPoint {
  title: string;
  headingId: string;
}

interface Summary {
  overview: string;
  keyPoints: KeyPoint[];
}

interface Props {
  slug: string;
  summary: Summary | null;
  hasAudio?: boolean;
  questions: string[] | null;
  pageType: 'journal' | 'project';
}

const { slug, summary, hasAudio = false, questions, pageType } = Astro.props;
const hasSummary = summary !== null;
const hasQuestions = questions !== null;
---

<div class="content-actions">
  <div class="content-actions-left">
    <button
      id="summary-btn"
      class={`ca-btn${hasSummary ? '' : ' ca-disabled'}`}
      aria-label="AI summary"
      disabled={!hasSummary}
    >
      Summarize <i class="ti ti-sparkles" aria-hidden="true"></i>
    </button>
    <button
      id="listen-btn"
      class={`ca-btn${hasAudio ? '' : ' ca-disabled'}`}
      aria-label="Listen to this entry"
      disabled={!hasAudio}
    >
      Listen <i class="ti ti-headphones" aria-hidden="true"></i>
    </button>
    <button
      id="ask-btn"
      class={`ca-btn${hasQuestions ? '' : ' ca-disabled'}`}
      aria-label="Ask AI about this entry"
      disabled={!hasQuestions}
    >
      Ask AI <i class="ti ti-message-question" aria-hidden="true"></i>
    </button>
  </div>
  <div class="content-actions-right">
    <button id="share-btn" class="ca-btn" aria-label="Share">
      Share <i class="ti ti-upload" aria-hidden="true"></i>
    </button>
    <div id="share-dropdown" class="share-dropdown hidden">
      <button class="share-item" data-action="copy">
        <i class="ti ti-link" aria-hidden="true"></i> Copy link
      </button>
      <div class="share-sep"></div>
      <a class="share-item" data-action="linkedin" target="_blank" rel="noopener noreferrer">
        <i class="ti ti-brand-linkedin" aria-hidden="true"></i> Share on LinkedIn
      </a>
      <a class="share-item" data-action="x" target="_blank" rel="noopener noreferrer">
        <i class="ti ti-brand-x" aria-hidden="true"></i> Share on X
      </a>
      <a class="share-item" data-action="bluesky" target="_blank" rel="noopener noreferrer">
        <i class="ti ti-brand-bluesky" aria-hidden="true"></i> Share on Bluesky
      </a>
    </div>
  </div>
</div>

<div id="summary-panel" class="summary-panel hidden"></div>

<!-- Listen panel: slug passed via data attribute so the client script can construct the audio URL -->
<div
  id="listen-panel"
  class="listen-panel hidden"
  data-slug={slug}
></div>

<!-- Ask AI panel: data attributes carry config to client script -->
<div
  id="ask-panel"
  class="ask-panel hidden"
  data-slug={slug}
  data-page-type={pageType}
  data-questions={JSON.stringify(questions ?? [])}
></div>

{hasSummary && (
  <script id="summary-data" type="application/json" set:html={JSON.stringify(summary)} />
)}

<style is:global>
  .content-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 0;
    margin-bottom: 24px;
    border-top: 1px solid #e7e5e4;
    border-bottom: 1px solid #e7e5e4;
  }

  .dark .content-actions {
    border-top-color: #292524;
    border-bottom-color: #292524;
  }

  .content-actions-left {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .content-actions-right {
    position: relative;
  }

  .ca-btn {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 13px;
    font-family: 'DM Sans', sans-serif;
    color: #78716c;
    background: none;
    border: none;
    border-radius: 6px;
    padding: 6px 10px;
    cursor: pointer;
    transition: all 150ms ease;
  }

  .ca-btn:hover,
  .ca-btn:focus-visible {
    background: #f5f5f4;
    color: #1c1917;
  }

  .dark .ca-btn:hover,
  .dark .ca-btn:focus-visible {
    background: #1c1917;
    color: #f5f5f4;
  }

  .ca-btn.ca-disabled,
  .ca-btn:disabled {
    opacity: 0.35;
    pointer-events: none;
  }

  /* Share dropdown */
  .share-dropdown {
    position: absolute;
    right: 0;
    top: calc(100% + 8px);
    background: #ffffff;
    border: 1px solid #e7e5e4;
    border-radius: 12px;
    padding: 6px;
    min-width: 188px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08), 0 1px 4px rgba(0, 0, 0, 0.04);
    z-index: 50;
  }

  .dark .share-dropdown {
    background: #1c1917;
    border-color: #292524;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.35);
  }

  .share-item {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    padding: 8px 10px;
    font-size: 13px;
    font-weight: 500;
    font-family: inherit;
    color: #44403c;
    background: transparent;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    transition: background 120ms, color 120ms;
    text-align: left;
    white-space: nowrap;
  }

  .share-item:hover {
    background: #f5f5f4;
    color: #0f766e;
  }

  .dark .share-item {
    color: #d6d3d1;
  }

  .dark .share-item:hover {
    background: #292524;
    color: #2dd4bf;
  }

  .share-sep {
    height: 1px;
    background: #e7e5e4;
    margin: 4px 6px;
  }

  .dark .share-sep {
    background: #292524;
  }

  /* Summary panel */
  .summary-panel {
    border: 1px solid #e7e5e4;
    border-radius: 12px;
    padding: 20px 24px;
    margin-bottom: 28px;
    background: #fafaf9;
  }

  .dark .summary-panel {
    background: #1c1917;
    border-color: #292524;
  }

  .summary-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }

  .summary-chip {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #0f766e;
    background: #ccfbf1;
    padding: 3px 8px;
    border-radius: 9999px;
  }

  .dark .summary-chip {
    color: #2dd4bf;
    background: rgba(45, 212, 191, 0.12);
  }

  .summary-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 6px;
    border: none;
    background: transparent;
    color: #a8a29e;
    cursor: pointer;
    font-size: 16px;
    transition: background 120ms, color 120ms;
    padding: 0;
  }

  .summary-close:hover {
    background: #e7e5e4;
    color: #57534e;
  }

  .dark .summary-close {
    color: #78716c;
  }

  .dark .summary-close:hover {
    background: #292524;
    color: #d6d3d1;
  }

  .summary-text {
    font-size: 14px;
    line-height: 1.65;
    color: #57534e;
    margin: 0 0 16px;
    padding-left: 12px;
  }

  .dark .summary-text {
    color: #a8a29e;
  }

  /* Blinking cursor during streaming */
  .ca-streaming::after {
    content: '▋';
    color: #0f766e;
    animation: ca-blink 500ms step-end infinite;
    margin-left: 1px;
  }

  .dark .ca-streaming::after {
    color: #2dd4bf;
  }

  @keyframes ca-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
