  /* ── Ask AI panel ──────────────────────────────────────────────────────── */
  .ask-panel {
    border: 1px solid #e7e5e4;
    border-radius: 12px;
    padding: 20px 24px;
    margin-bottom: 28px;
    background: #fafaf9;
  }

  .dark .ask-panel {
    background: #1c1917;
    border-color: #292524;
  }

  .ask-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .ask-chip {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #0f766e;
    background: #ccfbf1;
    padding: 3px 8px;
    border-radius: 9999px;
  }

  .dark .ask-chip {
    color: #2dd4bf;
    background: rgba(45, 212, 191, 0.12);
