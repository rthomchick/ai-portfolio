    background: #292524;
    border-color: #44403c;
  }

  .dark #ask-input:focus {
    border-color: #0d9488;
  }

  #ask-input::placeholder {
    color: #a8a29e;
  }

  #ask-send {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    border: none;
    background: #0f766e;
    color: #ffffff;
    font-size: 16px;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 150ms;
  }

  #ask-send:hover {
    background: #0d6460;
  }

  #ask-send:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .dark #ask-send {
    background: #0d9488;
  }

  .dark #ask-send:hover {
    background: #0f766e;
  }

  /* Code blocks in answers */
  .code-block {
    border: 1px solid #e7e5e4;
    border-radius: 8px;
    overflow: hidden;
    margin: 10px 0;
