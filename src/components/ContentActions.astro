  }

  .dark .code-block {
    border-color: #292524;
  }

  .code-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #f5f5f4;
    padding: 6px 12px;
    border-bottom: 1px solid #e7e5e4;
  }

  .dark .code-header {
    background: #292524;
    border-bottom-color: #44403c;
  }

  .code-filename {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: #78716c;
    font-family: monospace;
  }

  .dark .code-filename {
    color: #a8a29e;
  }

  .code-actions {
    display: flex;
    gap: 6px;
  }

  .code-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    font-family: 'DM Sans', sans-serif;
    color: #78716c;
    background: transparent;
    border: 1px solid #e7e5e4;
    border-radius: 5px;
    padding: 3px 7px;
    cursor: pointer;
    text-decoration: none;
    transition: background 120ms, color 120ms;
  }

  .code-btn:hover {
    background: #e7e5e4;
    color: #1c1917;
  }

  .dark .code-btn {
    color: #a8a29e;
    border-color: #44403c;
  }

  .dark .code-btn:hover {
    background: #44403c;
    color: #f5f5f4;
  }

  .code-body {
    margin: 0;
    padding: 14px 16px;
    background: #fafaf9;
    overflow-x: auto;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 12.5px;
    line-height: 1.6;
    color: #44403c;
  }

  .dark .code-body {
    background: #1c1917;
    color: #d6d3d1;
  }

  .code-body code {
    background: none;
    padding: 0;
    font-size: inherit;
    color: inherit;
  }

  /* Mobile: icons-only adjusts ca-btn, player stays full-width */
  @media (max-width: 639px) {
    .ca-btn {
      font-size: 0;
      padding: 8px;
      gap: 0;
    }

    .ca-btn i {
      font-size: 19px;
    }

    .ask-q-bubble {
      max-width: 92%;
    }
  }
</style>

<script>
  // ── Share ──────────────────────────────────────────────────────────────────
  const shareBtn = document.getElementById('share-btn');
  const shareDropdown = document.getElementById('share-dropdown');

  const pageUrl = window.location.href;
  const pageTitle = document.title.replace(/\s*—.*$/, '').trim();

  const linkedinLink = shareDropdown?.querySelector('[data-action="linkedin"]') as HTMLAnchorElement | null;
  const xLink = shareDropdown?.querySelector('[data-action="x"]') as HTMLAnchorElement | null;
  const blueskyLink = shareDropdown?.querySelector('[data-action="bluesky"]') as HTMLAnchorElement | null;

  if (linkedinLink) linkedinLink.href = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`;
  if (xLink) xLink.href = `https://twitter.com/intent/tweet?url=${encodeURIComponent(pageUrl)}&text=${encodeURIComponent(pageTitle)}`;
  if (blueskyLink) blueskyLink.href = `https://bsky.app/intent/compose?text=${encodeURIComponent(pageTitle + ' ' + pageUrl)}`;

  shareBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    shareDropdown?.classList.toggle('hidden');
  });

  shareDropdown?.querySelector('[data-action="copy"]')?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(pageUrl);
      const copyBtn = shareDropdown?.querySelector('[data-action="copy"]');
      if (copyBtn) {
        const original = copyBtn.innerHTML;
        copyBtn.innerHTML = '<i class="ti ti-check" aria-hidden="true"></i> Copied!';
        setTimeout(() => { copyBtn.innerHTML = original; }, 2000);
      }
    } catch {
      // clipboard not available
    }
    shareDropdown?.classList.add('hidden');
  });

  document.addEventListener('click', (e) => {
    if (!shareDropdown?.classList.contains('hidden')) {
      if (!shareBtn?.contains(e.target as Node) && !shareDropdown?.contains(e.target as Node)) {
        shareDropdown?.classList.add('hidden');
      }
    }
  });

  // ── Summary ────────────────────────────────────────────────────────────────
  const summaryBtn = document.getElementById('summary-btn');
  const summaryPanel = document.getElementById('summary-panel');
  const summaryDataEl = document.getElementById('summary-data');

  if (summaryDataEl && summaryPanel && summaryBtn) {
    const summary = JSON.parse(summaryDataEl.textContent || '{}');
    let rendered = false;

    summaryBtn.addEventListener('click', () => {
      if (!summaryPanel.classList.contains('hidden')) {
        summaryPanel.classList.add('hidden');
        return;
      }

      // One-panel rule: close others
      document.getElementById('listen-panel')?.classList.add('hidden');
      document.getElementById('ask-panel')?.classList.add('hidden');

      summaryPanel.classList.remove('hidden');

      if (!rendered) {
        const keyPointsHtml = summary.keyPoints.map((point: { headingId: string; title: string }) => `
          <a class="summary-link" data-target="${point.headingId}" style="opacity:0;transform:translateY(5px)">
            <i class="ti ti-arrow-right" style="color:#0F6E56;font-size:14px;margin-top:1px;flex-shrink:0;" aria-hidden="true"></i>
            <span class="summary-link-title">${point.title}</span>
          </a>
        `).join('');

        summaryPanel.innerHTML = `
          <div class="summary-header">
            <span class="summary-chip">AI summary</span>
            <button class="summary-close" id="summary-close" aria-label="Close summary"><i class="ti ti-x" aria-hidden="true"></i></button>
          </div>
          <p class="summary-text"></p>
          <div class="summary-takeaways-label" style="opacity:0">Key takeaways</div>
          <div>${keyPointsHtml}</div>
        `;

        rendered = true;

        summaryPanel.querySelectorAll<HTMLElement>('.summary-link').forEach(link => {
          link.addEventListener('click', () => {
            const targetId = link.dataset.target;
            if (targetId) {
              document.getElementById(targetId)?.scrollIntoView({ behavior: 'smooth' });
            }
          });
          link.addEventListener('keydown', (e: KeyboardEvent) => {
            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); link.click(); }
          });
        });
        document.getElementById('summary-close')?.addEventListener('click', () => {
          summaryPanel.classList.add('hidden');
        });

        const overviewEl = summaryPanel.querySelector<HTMLElement>('.summary-text');
        const labelEl = summaryPanel.querySelector<HTMLElement>('.summary-takeaways-label');
        const linkEls = summaryPanel.querySelectorAll<HTMLElement>('.summary-link');
        const text = summary.overview as string;

        if (!overviewEl) return;

        overviewEl.classList.add('ca-streaming');

        const STREAM_MS = 1100;
        const startTime = performance.now();

        function streamFrame(now: number) {
          const progress = Math.min((now - startTime) / STREAM_MS, 1);
          const chars = Math.floor(progress * text.length);
          overviewEl!.textContent = text.slice(0, chars);

          if (progress < 1) {
            requestAnimationFrame(streamFrame);
          } else {
            overviewEl!.textContent = text;
            overviewEl!.classList.remove('ca-streaming');
            setTimeout(() => {
              if (labelEl) {
                labelEl.style.transition = 'opacity 180ms ease';
                labelEl.style.opacity = '1';
              }
              linkEls.forEach((el, idx) => {
                setTimeout(() => {
                  el.style.transition = 'opacity 200ms ease, transform 200ms ease';
                  el.style.opacity = '1';
                  el.style.transform = 'translateY(0)';
                }, idx * 70);
              });
            }, 80);
          }
        }
        requestAnimationFrame(streamFrame);
      }
    });
  }

  // ── Listen (Web Speech API — v0) ───────────────────────────────────────────
  const listenBtn = document.getElementById('listen-btn');
  const listenPanel = document.getElementById('listen-panel');

  if (listenBtn && listenPanel && 'speechSynthesis' in window) {
    let utterance: SpeechSynthesisUtterance | null = null;
    let isPlaying = false;
    let rendered = false;

    function getArticleText(): string {
      const prose = document.querySelector<HTMLElement>('.prose, article, main');
      if (!prose) return document.body.innerText;

      const clone = prose.cloneNode(true) as HTMLElement;
      clone.querySelectorAll(
        'pre, code, .content-actions, .summary-panel, .listen-panel, .ask-panel, nav, footer, script, style'
      ).forEach(el => el.remove());

      return clone.innerText.replace(/\n{3,}/g, '\n\n').trim();
    }

    function formatTime(seconds: number): string {
      const m = Math.floor(seconds / 60);
      const s = Math.floor(seconds % 60);
      return `${m}:${s.toString().padStart(2, '0')}`;
    }

    function estimateDuration(text: string): number {
      return Math.ceil(text.split(/\s+/).length / 150) * 60;
    }

    function buildListenPanel() {
      listenPanel.innerHTML = `
        <div class="listen-header">
          <span class="listen-chip">Listen</span>
          <button class="summary-close" id="listen-close" aria-label="Close player">
            <i class="ti ti-x" aria-hidden="true"></i>
          </button>
        </div>
        <div class="listen-controls">
          <button class="listen-play-btn" id="listen-play" aria-label="Play">
            <i class="ti ti-player-play" aria-hidden="true"></i>
          </button>
          <div class="listen-progress-wrap">
            <input
              type="range"
              class="listen-progress-bar"
              id="listen-progress"
              min="0"
              max="100"
              value="0"
              step="0.1"
              aria-label="Playback position"
            />
            <span class="listen-time" id="listen-time">0:00</span>
          </div>
        </div>
      `;
      rendered = true;

      const playBtn = document.getElementById('listen-play')!;
      const progressBar = document.getElementById('listen-progress') as HTMLInputElement;
      const timeEl = document.getElementById('listen-time')!;
      const closeBtn = document.getElementById('listen-close')!;

      const articleText = getArticleText();
      const estimatedDuration = estimateDuration(articleText);

      let rafId: number | null = null;
      let startedAt: number | null = null;
      let pausedElapsed = 0;

      function startProgressTimer() {
        startedAt = performance.now();
        function tick() {
          if (!isPlaying) return;
          const elapsed = pausedElapsed + (performance.now() - startedAt!) / 1000;
          const clamped = Math.min(elapsed, estimatedDuration);
          const pct = (clamped / estimatedDuration) * 100;

          progressBar.value = String(pct);
          progressBar.style.setProperty('--pct', `${pct}%`);
          timeEl.textContent = formatTime(clamped);

          if (clamped < estimatedDuration) {
            rafId = requestAnimationFrame(tick);
          }
        }
        rafId = requestAnimationFrame(tick);
      }

      function stopProgressTimer() {
        if (rafId !== null) {
          cancelAnimationFrame(rafId);
          rafId = null;
        }
        if (startedAt !== null) {
          pausedElapsed += (performance.now() - startedAt) / 1000;
          startedAt = null;
        }
      }

      function setPlayIcon() {
        playBtn.innerHTML = '<i class="ti ti-player-play" style="margin-left:2px" aria-hidden="true"></i>';
        playBtn.setAttribute('aria-label', 'Play');
      }

      function setPauseIcon() {
        playBtn.innerHTML = '<i class="ti ti-player-pause" aria-hidden="true"></i>';
        playBtn.setAttribute('aria-label', 'Pause');
      }

      function resetState() {
        stopProgressTimer();
        pausedElapsed = 0;
        progressBar.value = '0';
        progressBar.style.setProperty('--pct', '0%');
        timeEl.textContent = '0:00';
        setPlayIcon();
        isPlaying = false;
        utterance = null;
      }

      playBtn.addEventListener('click', () => {
        if (isPlaying) {
          window.speechSynthesis.pause();
          stopProgressTimer();
          isPlaying = false;
          setPlayIcon();
        } else if (window.speechSynthesis.paused && utterance) {
          window.speechSynthesis.resume();
          isPlaying = true;
          setPauseIcon();
          startProgressTimer();
        } else {
          if (utterance) { utterance.onstart = null; utterance.onend = null; utterance.onerror = null; }
          window.speechSynthesis.cancel();
          pausedElapsed = 0;

          utterance = new SpeechSynthesisUtterance(articleText);
          utterance.rate = 0.95;
          utterance.lang = 'en-US';

          utterance.onstart = () => {
            isPlaying = true;
            setPauseIcon();
            startProgressTimer();
          };

          utterance.onend = () => { resetState(); };

          utterance.onerror = (e) => {
            if (e.error === 'interrupted') return;
            resetState();
            listenPanel.innerHTML += `<p class="listen-error">Playback error: ${e.error}</p>`;
          };

          window.speechSynthesis.speak(utterance);
        }
      });

      progressBar.addEventListener('input', () => {
        const pct = parseFloat(progressBar.value) / 100;
        const charOffset = Math.floor(pct * articleText.length);
        const remainingText = articleText.slice(charOffset);

        if (utterance) { utterance.onstart = null; utterance.onend = null; utterance.onerror = null; }
        window.speechSynthesis.cancel();
        stopProgressTimer();

        pausedElapsed = pct * estimatedDuration;
        progressBar.style.setProperty('--pct', `${pct * 100}%`);
        timeEl.textContent = formatTime(pausedElapsed);

        utterance = new SpeechSynthesisUtterance(remainingText);
        utterance.rate = 0.95;
        utterance.lang = 'en-US';

        utterance.onstart = () => {
          isPlaying = true;
          setPauseIcon();
          startProgressTimer();
        };

        utterance.onend = () => { resetState(); };
        utterance.onerror = (e) => {
          if (e.error === 'interrupted') return;
          resetState();
        };

        window.speechSynthesis.speak(utterance);
      });

      closeBtn.addEventListener('click', () => {
        window.speechSynthesis.cancel();
        resetState();
        listenPanel.classList.add('hidden');
      });

      setInterval(() => {
        if (isPlaying && window.speechSynthesis.speaking && !window.speechSynthesis.paused) {
          window.speechSynthesis.pause();
          window.speechSynthesis.resume();
        }
      }, 10000);
    }

    listenBtn.addEventListener('click', () => {
      // One-panel rule: close others
      summaryPanel?.classList.add('hidden');
      document.getElementById('ask-panel')?.classList.add('hidden');

      if (!listenPanel.classList.contains('hidden')) {
        window.speechSynthesis.cancel();
        listenPanel.classList.add('hidden');
        return;
      }

      listenPanel.classList.remove('hidden');
      if (!rendered) buildListenPanel();
    });

    window.addEventListener('beforeunload', () => {
      window.speechSynthesis.cancel();
    });
  }

  // ── Ask AI ─────────────────────────────────────────────────────────────────
  const askBtn = document.getElementById('ask-btn');
  const askPanel = document.getElementById('ask-panel');

  if (askBtn && askPanel && !askBtn.hasAttribute('disabled')) {
    const askSlug = askPanel.dataset.slug!;
    const askPageType = askPanel.dataset.pageType as 'journal' | 'project';
    const starterQuestions: string[] = JSON.parse(askPanel.dataset.questions || '[]');

    const entityLabel = askPageType === 'journal' ? 'entry' : 'project';
    let panelBuilt = false;
    let history: Array<{ q: string; a: string }> = [];
    let answerCount = 0;
    let streamingInProgress = false;

    function escHtml(s: string): string {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function processAnswerText(text: string): string {
      const codeRe = /```(\w*)\n([\s\S]*?)```/g;
      const parts: string[] = [];
      let last = 0;
      let m: RegExpExecArray | null;

      while ((m = codeRe.exec(text)) !== null) {
        parts.push(`<span class="ask-answer-text" style="white-space:pre-wrap">${escHtml(text.slice(last, m.index))}</span>`);
        const lang = m[1] || 'code';
        const code = m[2];
        parts.push(`<div class="code-block">
          <div class="code-header">
            <span class="code-filename"><i class="ti ti-file-code"></i> ${escHtml(lang)}</span>
            <div class="code-actions">
              <button class="code-btn copy-btn"><i class="ti ti-copy"></i> Copy</button>
            </div>
          </div>
          <pre class="code-body"><code>${escHtml(code)}</code></pre>
        </div>`);
        last = m.index + m[0].length;
      }

      if (last === 0) {
        // No code blocks — plain text span
        return `<span class="ask-answer-text" style="white-space:pre-wrap">${escHtml(text)}</span>`;
      }

      parts.push(`<span class="ask-answer-text" style="white-space:pre-wrap">${escHtml(text.slice(last))}</span>`);
      return parts.join('');
    }

    function wireCodeCopyBtns(container: HTMLElement, fullText: string) {
      const codeBlocks = container.querySelectorAll<HTMLElement>('.code-block');
      const codeRe = /```\w*\n([\s\S]*?)```/g;
      const codes: string[] = [];
      let m: RegExpExecArray | null;
      while ((m = codeRe.exec(fullText)) !== null) {
        codes.push(m[1]);
      }
      codeBlocks.forEach((block, idx) => {
        const btn = block.querySelector<HTMLButtonElement>('.copy-btn');
        if (!btn) return;
        const code = codes[idx] ?? '';
        btn.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(code);
            const orig = btn.innerHTML;
            btn.innerHTML = '<i class="ti ti-check"></i> Copied!';
            setTimeout(() => { btn.innerHTML = orig; }, 2000);
          } catch { /* clipboard not available */ }
        });
      });
    }

    function renderSourcesFooter(
      sources: Array<{
        type: string;
        heading_id?: string;
        heading_text?: string;
        related_slug?: string;
        related_title?: string;
        related_type?: string;
      }>
    ): string {
      if (!sources || sources.length === 0) return '';

      const links = sources.map(s => {
        if (s.type === 'section' && s.heading_id && s.heading_text) {
          return `<a class="source-link" href="#${escHtml(s.heading_id)}">↗ Jump to: ${escHtml(s.heading_text)}</a>`;
        }
        if (s.type === 'related' && s.related_slug) {
          if (askPageType === 'journal') {
            return `<a class="source-link" href="/projects/${escHtml(s.related_slug)}">Go to project details</a>`;
          } else {
            const weekMatch = s.related_slug.match(/week-(\d+)/);
            const weekNum = weekMatch ? weekMatch[1] : '';
            const label = weekNum ? `Week ${weekNum} journal →` : `${escHtml(s.related_title || s.related_slug)} →`;
            return `<a class="source-link" href="/journal/${escHtml(s.related_slug)}">${label}</a>`;
          }
        }
        return '';
      }).filter(Boolean);

      if (links.length === 0) return '';
      return `<div class="ask-answer-footer">${links.join('')}</div>`;
    }

    async function submitQuestion(question: string) {
      if (streamingInProgress || !question.trim()) return;

      const conversationEl = document.getElementById('ask-conversation')!;
      const startersEl = askPanel.querySelector<HTMLElement>('.ask-starters');
      const inputEl = document.getElementById('ask-input') as HTMLInputElement | null;
      const sendBtn = document.getElementById('ask-send') as HTMLButtonElement | null;

      // Hide starters after first question
      if (startersEl) {
        startersEl.style.transition = 'opacity 200ms';
        startersEl.style.opacity = '0';
        setTimeout(() => { startersEl.style.display = 'none'; }, 200);
      }

      // Append question bubble
      const qBubble = document.createElement('div');
      qBubble.className = 'ask-q-bubble';
      qBubble.textContent = question;
      conversationEl.appendChild(qBubble);

      // Append answer container
      const n = ++answerCount;
      const answerEl = document.createElement('div');
      answerEl.className = 'ask-answer';
      answerEl.id = `ask-answer-${n}`;
      answerEl.innerHTML = `
        <div class="ask-answer-body">
          <span class="ask-answer-text ask-answer-loading">Searching this ${entityLabel}…</span><span class="ca-streaming-cursor"></span>
        </div>`;
      conversationEl.appendChild(answerEl);
      answerEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

      const textEl = answerEl.querySelector<HTMLElement>('.ask-answer-text')!;
      const cursorEl = answerEl.querySelector<HTMLElement>('.ca-streaming-cursor')!;
      const bodyEl = answerEl.querySelector<HTMLElement>('.ask-answer-body')!;

      if (inputEl) inputEl.value = '';
      if (sendBtn) sendBtn.disabled = true;
      streamingInProgress = true;

      // SSE stream state
      let receivedText = '';
      let firstToken = true;
      let pendingFlush = '';
      let rafQueued = false;

      function flushToDOM() {
        if (pendingFlush) {
          if (firstToken) {
            textEl.classList.remove('ask-answer-loading');
            textEl.textContent = '';
            firstToken = false;
          }
          textEl.textContent = (textEl.textContent || '') + pendingFlush;
          pendingFlush = '';
          answerEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
        rafQueued = false;
      }

      let sseBuffer = '';
      let currentEvent = '';

      function handleSseLine(line: string) {
        if (line.startsWith('event: ')) {
          currentEvent = line.slice(7).trim();
        } else if (line.startsWith('data: ')) {
          const data = line.slice(6);
          if (currentEvent === 'ai-chunk') {
            const text: string = JSON.parse(data);
            receivedText += text;
            pendingFlush += text;
            if (!rafQueued) {
              rafQueued = true;
              requestAnimationFrame(flushToDOM);
            }
          } else if (currentEvent === 'sources') {
            const sources = JSON.parse(data);
            const footerHtml = renderSourcesFooter(sources);
            if (footerHtml) {
              const footer = document.createElement('div');
              footer.innerHTML = footerHtml;
              answerEl.appendChild(footer.firstElementChild!);
            }
          } else if (currentEvent === 'error') {
            textEl.classList.remove('ask-answer-loading');
            textEl.textContent = 'Something went wrong. Please try again.';
            cursorEl.remove();
          }
          currentEvent = '';
        }
      }

      try {
        const response = await fetch('/api/search', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            query: question,
            context: askPageType,
            slug: askSlug,
            history,
            stream: true,
          }),
        });

        if (!response.ok || !response.body) throw new Error('Stream failed');

        const reader = response.body.getReader();
        const decoder = new TextDecoder();

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;

          sseBuffer += decoder.decode(value, { stream: true });
          const lines = sseBuffer.split('\n');
          sseBuffer = lines.pop() ?? '';

          for (const line of lines) {
            handleSseLine(line);
          }
        }

        // Final flush
        if (pendingFlush) flushToDOM();

        // Replace textContent with processed HTML (handles code blocks)
        if (receivedText) {
          const hasCodeBlock = /```/.test(receivedText);
          if (hasCodeBlock) {
            bodyEl.innerHTML = processAnswerText(receivedText);
            wireCodeCopyBtns(bodyEl, receivedText);
          }
          // Re-find cursor after potential innerHTML swap
          bodyEl.querySelector('.ca-streaming-cursor')?.remove();
        } else {
          cursorEl.remove();
        }

      } catch {
        textEl.classList.remove('ask-answer-loading');
        textEl.textContent = 'Something went wrong. Please try again.';
        cursorEl.remove();
      }

      // Append to history
      history.push({ q: question, a: receivedText });

      streamingInProgress = false;
      if (sendBtn) sendBtn.disabled = false;
      if (inputEl) {
        inputEl.focus();
      }
    }

    function buildAskPanel() {
      const startersHtml = starterQuestions.map(q =>
        `<button class="starter-btn">${escHtml(q)}</button>`
      ).join('');

      askPanel.innerHTML = `
        <div class="ask-header">
          <span class="ask-chip">Ask AI</span>
          <button class="summary-close" id="ask-close" aria-label="Close Ask AI"><i class="ti ti-x" aria-hidden="true"></i></button>
        </div>
        <div class="ask-starters">
          <div class="starters-label">Suggested questions</div>
          ${startersHtml}
        </div>
        <div id="ask-conversation"></div>
        <p class="scope-note">Answers are scoped to this ${entityLabel}.</p>
        <div class="ask-input-row">
          <input type="text" id="ask-input" placeholder="Ask about this ${entityLabel}…" autocomplete="off" />
          <button id="ask-send">→</button>
        </div>
      `;

      panelBuilt = true;

      // Stagger starters in
      const starterBtns = askPanel.querySelectorAll<HTMLElement>('.starter-btn');
      starterBtns.forEach((btn, idx) => {
        setTimeout(() => {
          btn.style.transition = 'opacity 200ms ease, transform 200ms ease';
          btn.style.opacity = '1';
          btn.style.transform = 'translateY(0)';
        }, 60 + idx * 70);
      });

      // Wire starter buttons
      starterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          submitQuestion(btn.textContent?.trim() ?? '');
        });
      });

      // Wire close button
      document.getElementById('ask-close')?.addEventListener('click', () => {
        askPanel.classList.add('hidden');
      });

      // Wire input + send
      const inputEl = document.getElementById('ask-input') as HTMLInputElement;
      const sendBtn = document.getElementById('ask-send') as HTMLButtonElement;

      inputEl?.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          submitQuestion(inputEl.value.trim());
        }
      });

      sendBtn?.addEventListener('click', () => {
        submitQuestion(inputEl?.value.trim() ?? '');
      });
    }

    askBtn.addEventListener('click', () => {
      // One-panel rule: close others
      summaryPanel?.classList.add('hidden');
      listenPanel?.classList.add('hidden');

      if (!askPanel.classList.contains('hidden')) {
        askPanel.classList.add('hidden');
        return;
      }

      askPanel.classList.remove('hidden');
      if (!panelBuilt) buildAskPanel();
    });
  }
</script>
