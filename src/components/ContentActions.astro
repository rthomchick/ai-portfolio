  }

  .dark .listen-play-btn {
    background: #0d9488;
  }

  .dark .listen-play-btn:hover {
    background: #0f766e;
  }

  /* Play icon nudge for optical centering */
  .listen-play-btn .ti-player-play {
    margin-left: 2px;
  }

  .listen-progress-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  .listen-progress-bar {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 3px;
    border-radius: 9999px;
    background: #e7e5e4;
    cursor: pointer;
    outline: none;
  }

  .dark .listen-progress-bar {
    background: #44403c;
  }

  /* Webkit fill */
  .listen-progress-bar::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #0f766e;
    cursor: pointer;
    margin-top: -4.5px;
    transition: transform 120ms ease;
  }

  .listen-progress-bar::-webkit-slider-thumb:hover {
    transform: scale(1.3);
  }

  .listen-progress-bar::-webkit-slider-runnable-track {
    height: 3px;
    border-radius: 9999px;
  }

  /* Firefox */
  .listen-progress-bar::-moz-range-thumb {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #0f766e;
    border: none;
    cursor: pointer;
  }

  .listen-progress-bar::-moz-range-track {
    height: 3px;
    background: #e7e5e4;
    border-radius: 9999px;
  }

  .dark .listen-progress-bar::-moz-range-track {
    background: #44403c;
  }

  .listen-time {
    font-size: 11px;
    color: #a8a29e;
    font-variant-numeric: tabular-nums;
