    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #a8a29e;
    margin-bottom: 4px;
    padding: 0 12px;
  }

  .summary-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border-radius: 6px;
    cursor: pointer;
    transition: background 120ms ease;
    text-decoration: none;
  }

  .summary-link:hover {
    background: #ffffff;
  }

  .dark .summary-link:hover {
    background: #292524;
  }

  .summary-link-title {
    font-size: 13px;
    font-weight: 500;
    color: #0F6E56;
  }

  .dark .summary-link-title {
    color: #2dd4bf;
  }

  /* ── Listen panel ──────────────────────────────────────────────────────── */
  .listen-panel {
    border: 1px solid #e7e5e4;
    border-radius: 12px;
    padding: 16px 20px;
    margin-bottom: 28px;
    background: #fafaf9;
  }

  .dark .listen-panel {
    background: #1c1917;
    border-color: #292524;
  }

  .listen-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }

  .listen-chip {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #0f766e;
    background: #ccfbf1;
    padding: 3px 8px;
    border-radius: 9999px;
  }

  .dark .listen-chip {
    color: #2dd4bf;
    background: rgba(45, 212, 191, 0.12);
  }

  /* Reuse .summary-close styles — identical close button pattern */

  .listen-controls {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .listen-play-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: none;
    background: #0f766e;
    color: #ffffff;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 150ms ease, transform 100ms ease;
