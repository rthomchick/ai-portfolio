  .starter-btn {
    display: block;
    width: 100%;
    text-align: left;
    font-size: 13px;
    font-family: 'DM Sans', sans-serif;
    color: #44403c;
    background: #ffffff;
    border: 1px solid #e7e5e4;
    border-radius: 8px;
    padding: 8px 12px;
    margin-bottom: 6px;
