    color: #0d6460;
  }

  .dark .source-link {
    color: #2dd4bf;
    background: rgba(45, 212, 191, 0.08);
    border-color: rgba(45, 212, 191, 0.2);
  }

  .dark .source-link:hover {
    background: rgba(45, 212, 191, 0.16);
