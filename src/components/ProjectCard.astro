---
export interface Props {
  title: string;
  description: string;
  status: 'deployed' | 'built' | 'planning';
  slug: string;
}

const { title, description, status, slug } = Astro.props;

const badgeClasses = {
  deployed: 'bg-teal-50 text-teal-600 dark:bg-teal-950 dark:text-teal-400',
  built: 'bg-stone-100 text-stone-500 dark:bg-stone-800 dark:text-stone-400',
  planning: 'bg-stone-50 text-stone-400 dark:bg-stone-800 dark:text-stone-500',
};

const badgeLabel = {
  deployed: 'live',
  built: 'built',
  planning: 'planning',
};
---

<article class="border border-stone-200 dark:border-stone-800 rounded-lg p-6 flex flex-col gap-3 dark:bg-stone-950">
  <div class="flex items-start justify-between gap-3">
    <h3 class="text-base font-medium text-stone-900 dark:text-stone-100 leading-snug">{title}</h3>
    <span class={`text-xs px-2 py-0.5 rounded-full font-medium shrink-0 ${badgeClasses[status]}`}>
      {badgeLabel[status]}
    </span>
  </div>
  <p class="text-sm text-stone-500 dark:text-stone-400 leading-relaxed flex-1">{description}</p>
  <a href={`/projects/${slug}`} class="text-sm text-teal-600 dark:text-teal-400 hover:underline font-medium mt-auto">
    View project →
  </a>
</article>
