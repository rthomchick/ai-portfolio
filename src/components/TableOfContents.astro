---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface TocItem {
  depth: number;
  slug: string;
  text: string;
  children: { depth: number; slug: string; text: string }[];
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

const tocItems: TocItem[] = [];
let currentH2: TocItem | null = null;

for (const h of headings) {
  if (h.depth === 2) {
    currentH2 = { ...h, children: [] };
    tocItems.push(currentH2);
  } else if (h.depth === 3 && currentH2) {
    currentH2.children.push(h);
  }
}
---

{tocItems.length > 0 && (
  <div class="toc-wrapper">
    <!-- Inline TOC: visible <1088px, appears above prose via order:-1 -->
    <div class="toc-inline">
      <button class="toc-inline-header" aria-expanded="false" aria-controls="toc-inline-body">
        <span>
          <i class="ti ti-list" aria-hidden="true"></i> On this page
        </span>
        <i class="ti ti-chevron-down toc-inline-chevron" aria-hidden="true"></i>
      </button>
      <nav class="toc-inline-body hidden" id="toc-inline-body" aria-label="Table of contents">
        {tocItems.map(h2 => (
          <>
            <a class="toc-inline-link" href={`#${h2.slug}`}>
              <i class="ti ti-arrow-right" aria-hidden="true"></i> {h2.text}
            </a>
            {h2.children.map(h3 => (
              <a class="toc-inline-link toc-inline-h3" href={`#${h3.slug}`}>
                <i class="ti ti-arrow-right" aria-hidden="true"></i> {h3.text}
              </a>
            ))}
          </>
        ))}
      </nav>
    </div>

    <!-- Sidebar TOC: visible ≥1088px, sticky alongside prose -->
    <nav class="toc-sidebar" aria-label="Table of contents">
      <div class="toc-sidebar-label">On this page</div>
      {tocItems.map(h2 => (
        <>
          <a class="toc-item toc-h2" href={`#${h2.slug}`}>{h2.text}</a>
          {h2.children.length > 0 && (
            <div class="toc-h3-group">
              {h2.children.map(h3 => (
                <a class="toc-item toc-h3" href={`#${h3.slug}`}>{h3.text}</a>
              ))}
            </div>
          )}
        </>
      ))}
    </nav>
  </div>
)}

<style>
/* ── Wrapper ── */
.toc-wrapper {
  /* At <1088px: flex-direction:column parent, use order:-1 to appear before prose */
  order: -1;
  width: 100%;
}

@media (min-width: 1088px) {
  .toc-wrapper {
    order: 2;
    width: 200px;
    flex-shrink: 0;
    position: sticky;
    top: 80px;
    align-self: start;
  }
}

/* ── Sidebar TOC (desktop) ── */
.toc-sidebar {
  display: none;
}

@media (min-width: 1088px) {
  .toc-sidebar {
    display: block;
  }

  .toc-inline {
    display: none;
  }
}

.toc-sidebar-label {
  font-size: 11px;
  font-weight: 500;
  color: #78716c;
  margin-bottom: 12px;
  font-family: 'DM Sans', sans-serif;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

:global(.dark) .toc-sidebar-label {
  color: #a8a29e;
}

.toc-item {
  display: block;
  font-size: 13px;
  line-height: 1.4;
  color: #78716c;
  text-decoration: none;
  padding: 5px 0;
  transition: color 120ms;
  font-family: 'DM Sans', sans-serif;
}

:global(.dark) .toc-item {
  color: #a8a29e;
}

.toc-item:hover {
  color: #1c1917;
}

:global(.dark) .toc-item:hover {
  color: #f5f5f4;
}

.toc-item.active {
  color: #0f766e;
}

:global(.dark) .toc-item.active {
  color: #2dd4bf;
}

/* ── H3 group and items ── */
.toc-h3-group {
  border-left: 1.5px solid #e7e5e4;
  margin-left: 4px;
  padding-left: 0;
  margin-bottom: 2px;
}

:global(.dark) .toc-h3-group {
  border-left-color: #44403c;
}

.toc-h3 {
  font-size: 12px;
  padding: 3px 0 3px 10px;
  border-left: 1.5px solid transparent;
  margin-left: -1.5px;
  transition: border-color 120ms, color 120ms;
}

.toc-h3.active {
  border-left-color: #0f766e;
}

:global(.dark) .toc-h3.active {
  border-left-color: #2dd4bf;
}

/* ── Inline TOC (mobile) ── */
.toc-inline {
  border: 0.5px solid #e7e5e4;
  border-radius: 8px;
  margin-bottom: 20px;
  overflow: hidden;
}

:global(.dark) .toc-inline {
  border-color: #44403c;
}

.toc-inline-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 10px 14px;
  background: #fafaf9;
  border: none;
  cursor: pointer;
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  font-weight: 500;
  color: #1c1917;
}

:global(.dark) .toc-inline-header {
  background: #1c1917;
  color: #f5f5f4;
}

.toc-inline-header span {
  display: flex;
  align-items: center;
  gap: 6px;
}

.toc-inline-chevron {
  font-size: 14px;
  color: #78716c;
  transition: transform 200ms ease;
}

:global(.dark) .toc-inline-chevron {
  color: #a8a29e;
}

.toc-inline.open .toc-inline-chevron {
  transform: rotate(180deg);
}

.toc-inline-body.hidden {
  display: none;
}

.toc-inline-body {
  padding: 6px 14px 12px;
  display: flex;
  flex-direction: column;
}

.toc-inline-link {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  color: #78716c;
  text-decoration: none;
  padding: 4px 0;
  font-family: 'DM Sans', sans-serif;
}

:global(.dark) .toc-inline-link {
  color: #a8a29e;
}

.toc-inline-link i {
  font-size: 11px;
  color: #0f766e;
  flex-shrink: 0;
}

:global(.dark) .toc-inline-link i {
  color: #2dd4bf;
}

.toc-inline-link:hover {
  color: #1c1917;
}

:global(.dark) .toc-inline-link:hover {
  color: #f5f5f4;
}

.toc-inline-h3 {
  padding-left: 18px;
  font-size: 12px;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  // ── Inline TOC toggle ──
  const inlineToc = document.querySelector('.toc-inline') as HTMLElement | null;
  const inlineHeader = document.querySelector('.toc-inline-header') as HTMLButtonElement | null;
  const inlineBody = document.getElementById('toc-inline-body');

  inlineHeader?.addEventListener('click', () => {
    if (!inlineBody) return;
    const willExpand = inlineBody.classList.contains('hidden');
    inlineBody.classList.toggle('hidden', !willExpand);
    inlineToc?.classList.toggle('open', willExpand);
    inlineHeader.setAttribute('aria-expanded', String(willExpand));
  });

  inlineBody?.querySelectorAll('.toc-inline-link').forEach(link => {
    link.addEventListener('click', () => {
      inlineBody.classList.add('hidden');
      inlineToc?.classList.remove('open');
      inlineHeader?.setAttribute('aria-expanded', 'false');
    });
  });

  // ── Sidebar active-section tracking (desktop only) ──
  if (!window.matchMedia('(min-width: 1088px)').matches) return;

  function setActiveFromHash() {
    const hash = window.location.hash.slice(1);
    document.querySelectorAll('.toc-item').forEach(item => {
      const itemHash = item.getAttribute('href')?.slice(1);
      item.classList.toggle('active', itemHash === hash);
    });
  }

  // After a TOC click the browser fires scroll events before hashchange, so
  // the scroll handler overrides the clicked item before we can suppress it.
  // Fix: intercept clicks directly, suppress scroll updates immediately, and
  // set the active item from the link's own href rather than waiting for the
  // hash to update. Keep hashchange for back/forward navigation.
  let suppressScrollUntil = 0;

  document.querySelectorAll('.toc-item').forEach(link => {
    link.addEventListener('click', () => {
      suppressScrollUntil = Date.now() + 1000;
      document.querySelectorAll('.toc-item').forEach(el => el.classList.remove('active'));
      link.classList.add('active');
    });
  });

  window.addEventListener('hashchange', () => {
    suppressScrollUntil = Date.now() + 1000;
    setActiveFromHash();
  });

  // Set initial state on load
  setActiveFromHash();

  // Update hash on scroll to keep it in sync.
  // Threshold is pinned to just below the sticky nav (~100px) rather than
  // 30% of viewport height. The large 30% threshold caused short sections
  // (e.g. Supabase Persistence, only ~4 lines) to immediately "lose" to the
  // next heading because both were above the generous threshold simultaneously.
  const proseHeadings = Array.from(document.querySelectorAll('.prose h2, .prose h3'));
  const SCROLL_THRESHOLD = 100; // px — just past the sticky nav

  function updateHashOnScroll() {
    if (Date.now() < suppressScrollUntil) return;
    let current = null;
    for (const h of proseHeadings) {
      if (h.getBoundingClientRect().top <= SCROLL_THRESHOLD) {
        current = h;
      }
    }
    if (current && current.id !== window.location.hash.slice(1)) {
      history.replaceState(null, '', `#${current.id}`);
      setActiveFromHash();
    }
  }

  window.addEventListener('scroll', updateHashOnScroll, { passive: true });
});
</script>
