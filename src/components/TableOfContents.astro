---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface TocItem {
  depth: 2 | 3;
  slug: string;
  text: string;
  children: TocItem[];
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

const tocItems: TocItem[] = [];
let currentH2: TocItem | null = null;

for (const h of headings) {
  if (h.depth === 2) {
    currentH2 = { depth: 2, slug: h.slug, text: h.text, children: [] };
    tocItems.push(currentH2);
  } else if (h.depth === 3 && currentH2) {
    currentH2.children.push({ depth: 3, slug: h.slug, text: h.text, children: [] });
  }
}
---

{tocItems.length > 0 && (
  <div class="toc-wrapper">
    <!-- Inline TOC: visible <1088px, appears above prose via order:-1 -->
    <div class="toc-inline">
      <button class="toc-inline-header" aria-expanded="false" aria-controls="toc-inline-body">
        <span>
          <i class="ti ti-list" aria-hidden="true"></i> On this page
        </span>
        <i class="ti ti-chevron-down toc-inline-chevron" aria-hidden="true"></i>
      </button>
      <nav class="toc-inline-body hidden" id="toc-inline-body" aria-label="Table of contents">
        {tocItems.map(h2 => (
          <Fragment>
            <a class="toc-inline-link" href={`#${h2.slug}`}>
              <i class="ti ti-arrow-right" aria-hidden="true"></i> {h2.text}
            </a>
            {h2.children.map(h3 => (
              <a class="toc-inline-link toc-inline-link-h3" href={`#${h3.slug}`}>
                <i class="ti ti-corner-down-right" aria-hidden="true"></i> {h3.text}
              </a>
            ))}
          </Fragment>
        ))}
      </nav>
    </div>

    <!-- Sidebar TOC: visible ≥1088px, sticky alongside prose -->
    <nav class="toc-sidebar" aria-label="Table of contents">
      <div class="toc-sidebar-label">On this page</div>
      {tocItems.map(h2 => (
        <div class="toc-group">
          <a
            class="toc-item"
            href={`#${h2.slug}`}
            data-heading-slug={h2.slug}
          >{h2.text}</a>
          {h2.children.length > 0 && (
            <div class="toc-children">
              {h2.children.map(h3 => (
                <a
                  class="toc-item toc-item-h3"
                  href={`#${h3.slug}`}
                  data-heading-slug={h3.slug}
                  data-parent-slug={h2.slug}
                >{h3.text}</a>
              ))}
            </div>
          )}
        </div>
      ))}
    </nav>
  </div>
)}

<style>
/* ── Wrapper ── */
.toc-wrapper {
  /* At <1088px: flex-direction:column parent, use order:-1 to appear before prose */
  order: -1;
  width: 100%;
}

@media (min-width: 1088px) {
  .toc-wrapper {
    order: 2;
    width: 200px;
    flex-shrink: 0;
    position: sticky;
    top: 80px;
    align-self: start;
  }
}

/* ── Sidebar TOC (desktop) ── */
.toc-sidebar {
  display: none;
}

@media (min-width: 1088px) {
  .toc-sidebar {
    display: block;
  }

  .toc-inline {
    display: none;
  }
}

.toc-sidebar-label {
  font-size: 13px;
  font-weight: 500;
  color: #1c1917;
  margin-bottom: 12px;
  font-family: 'DM Sans', sans-serif;
}

:global(.dark) .toc-sidebar-label {
  color: #f5f5f4;
}

/* ── H2 TOC items ── */
.toc-item {
  display: block;
  font-size: 13px;
  line-height: 1.4;
  color: #78716c;
  text-decoration: none;
  padding: 5px 0;
  transition: color 120ms;
  font-family: 'DM Sans', sans-serif;
}

:global(.dark) .toc-item {
  color: #a8a29e;
}

.toc-item:hover {
  color: #1c1917;
}

:global(.dark) .toc-item:hover {
  color: #f5f5f4;
}

.toc-item.active {
  color: #0f766e;
}

:global(.dark) .toc-item.active {
  color: #2dd4bf;
}

/* Parent H2 when a child H3 is active */
.toc-item.parent-active {
  color: #0f766e;
  opacity: 0.75;
}

:global(.dark) .toc-item.parent-active {
  color: #2dd4bf;
  opacity: 0.75;
}

/* ── H3 TOC items ── */
.toc-children {
  padding-left: 12px;
}

.toc-item-h3 {
  font-size: 12px;
  color: #a8a29e;
  padding: 3px 0;
}

:global(.dark) .toc-item-h3 {
  color: #78716c;
}

.toc-item-h3:hover {
  color: #57534e;
}

:global(.dark) .toc-item-h3:hover {
  color: #d6d3d1;
}

.toc-item-h3.active {
  color: #44403c;
}

:global(.dark) .toc-item-h3.active {
  color: #d6d3d1;
}

/* ── Inline TOC (mobile) ── */
.toc-inline {
  border: 0.5px solid #e7e5e4;
  border-radius: 8px;
  margin-bottom: 20px;
  overflow: hidden;
}

:global(.dark) .toc-inline {
  border-color: #44403c;
}

.toc-inline-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 10px 14px;
  background: #fafaf9;
  border: none;
  cursor: pointer;
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  font-weight: 500;
  color: #1c1917;
}

:global(.dark) .toc-inline-header {
  background: #1c1917;
  color: #f5f5f4;
}

.toc-inline-header span {
  display: flex;
  align-items: center;
  gap: 6px;
}

.toc-inline-chevron {
  font-size: 14px;
  color: #78716c;
  transition: transform 200ms ease;
}

:global(.dark) .toc-inline-chevron {
  color: #a8a29e;
}

.toc-inline.open .toc-inline-chevron {
  transform: rotate(180deg);
}

.toc-inline-body.hidden {
  display: none;
}

.toc-inline-body {
  padding: 6px 14px 12px;
  display: flex;
  flex-direction: column;
}

.toc-inline-link {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  color: #78716c;
  text-decoration: none;
  padding: 4px 0;
  font-family: 'DM Sans', sans-serif;
}

:global(.dark) .toc-inline-link {
  color: #a8a29e;
}

.toc-inline-link i {
  font-size: 11px;
  color: #0f766e;
  flex-shrink: 0;
}

:global(.dark) .toc-inline-link i {
  color: #2dd4bf;
}

.toc-inline-link:hover {
  color: #1c1917;
}

:global(.dark) .toc-inline-link:hover {
  color: #f5f5f4;
}

/* H3 inline links */
.toc-inline-link-h3 {
  font-size: 12px;
  padding-left: 12px;
  color: #a8a29e;
}

:global(.dark) .toc-inline-link-h3 {
  color: #78716c;
}

.toc-inline-link-h3 i {
  font-size: 10px;
  color: #a8a29e;
}

:global(.dark) .toc-inline-link-h3 i {
  color: #78716c;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  // ── Inline TOC toggle ──
  const inlineToc = document.querySelector('.toc-inline') as HTMLElement | null;
  const inlineHeader = document.querySelector('.toc-inline-header') as HTMLButtonElement | null;
  const inlineBody = document.getElementById('toc-inline-body');

  inlineHeader?.addEventListener('click', () => {
    if (!inlineBody) return;
    const willExpand = inlineBody.classList.contains('hidden');
    inlineBody.classList.toggle('hidden', !willExpand);
    inlineToc?.classList.toggle('open', willExpand);
    inlineHeader.setAttribute('aria-expanded', String(willExpand));
  });

  inlineBody?.querySelectorAll('.toc-inline-link').forEach(link => {
    link.addEventListener('click', () => {
      inlineBody.classList.add('hidden');
      inlineToc?.classList.remove('open');
      inlineHeader?.setAttribute('aria-expanded', 'false');
    });
  });

  // ── Sidebar active-section tracking (desktop only) ──
  if (!window.matchMedia('(min-width: 1088px)').matches) return;

  function setActiveFromSlug(slug: string) {
    document.querySelectorAll('.toc-item').forEach(item => {
      item.classList.remove('active', 'parent-active');
    });

    if (!slug) return;

    const activeItem = document.querySelector(`.toc-item[data-heading-slug="${CSS.escape(slug)}"]`) as HTMLElement | null;
    if (activeItem) {
      activeItem.classList.add('active');
      const parentSlug = activeItem.dataset.parentSlug;
      if (parentSlug) {
        const parentItem = document.querySelector(`.toc-item[data-heading-slug="${CSS.escape(parentSlug)}"]`);
        parentItem?.classList.add('parent-active');
      }
    }
  }

  function setActiveFromHash() {
    setActiveFromSlug(window.location.hash.slice(1));
  }

  // Activate on hash change (TOC click, back/forward, direct URL)
  window.addEventListener('hashchange', setActiveFromHash);

  // Set initial state on load
  setActiveFromHash();

  // Update hash on scroll to keep it in sync (track both H2 and H3)
  const proseHeadings = Array.from(document.querySelectorAll('.prose h2, .prose h3'));

  function updateHashOnScroll() {
    const threshold = window.innerHeight * 0.30;
    let current: Element | null = null;
    for (const h of proseHeadings) {
      if (h.getBoundingClientRect().top <= threshold) {
        current = h;
      }
    }
    if (current && current.id !== window.location.hash.slice(1)) {
      history.replaceState(null, '', `#${current.id}`);
      setActiveFromHash();
    }
  }

  window.addEventListener('scroll', updateHashOnScroll, { passive: true });
});
</script>
