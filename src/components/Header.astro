---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { href: '/journal', label: 'Journal' },
  { href: '/projects', label: 'Projects' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-stone-200 dark:border-stone-800 dark:bg-stone-950">
  <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="text-stone-900 dark:text-stone-100 font-medium text-base no-underline hover:text-teal-600 dark:hover:text-teal-400 transition-colors">
      Richard Thomchick
    </a>
    <nav class="flex items-center gap-6">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`text-sm transition-colors no-underline ${
            currentPath.startsWith(link.href)
              ? 'text-stone-900 dark:text-stone-100 font-medium'
              : 'text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-teal-400'
          }`}
        >
          {link.label}
        </a>
      ))}
      <ThemeToggle />
    </nav>
  </div>
</header>
