---
const navLinks = [
  { href: '/journal', label: 'Journal' },
  { href: '/projects', label: 'Projects' },
  { href: '/about', label: 'About' },
  { href: '/search', label: 'Search' },
];

const currentPath = Astro.url.pathname;
---

<header data-pagefind-ignore class="relative border-b border-stone-200 dark:border-stone-800 dark:bg-stone-950">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
    <a href="/" class="text-stone-900 dark:text-stone-100 font-medium text-base no-underline hover:text-teal-600 dark:hover:text-teal-400 transition-colors">
      Richard Thomchick
    </a>

    <!-- Desktop nav (hidden below sm) -->
    <nav class="hidden sm:flex items-center gap-6">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`text-sm transition-colors no-underline ${
            currentPath.startsWith(link.href)
              ? 'text-stone-900 dark:text-stone-100 font-medium'
              : 'text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-teal-400'
          }`}
        >
          {link.label}
        </a>
      ))}
      <!-- Desktop theme toggle -->
      <button
        id="theme-toggle"
        aria-label="Toggle theme"
        class="text-stone-500 dark:text-stone-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-600 dark:focus-visible:ring-teal-400 rounded-sm"
      >
        <svg id="icon-light" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
        <svg id="icon-dark" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
        </svg>
        <svg id="icon-system" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
          <rect width="20" height="14" x="2" y="3" rx="2"/>
          <path d="M8 21h8M12 17v4"/>
        </svg>
      </button>
    </nav>

    <!-- Mobile controls (visible below sm) -->
    <div class="flex items-center gap-4 sm:hidden">
      <!-- Mobile theme toggle -->
      <button
        id="theme-toggle-mobile"
        aria-label="Toggle theme"
        class="text-stone-500 dark:text-stone-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors"
      >
        <svg id="icon-light-mobile" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
        <svg id="icon-dark-mobile" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
        </svg>
        <svg id="icon-system-mobile" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
          <rect width="20" height="14" x="2" y="3" rx="2"/>
          <path d="M8 21h8M12 17v4"/>
        </svg>
      </button>
      <!-- Hamburger button -->
      <button
        id="mobile-menu-toggle"
        aria-label="Open menu"
        class="text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-stone-100 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile dropdown menu -->
  <div id="mobile-menu" class="hidden sm:hidden absolute top-full left-0 right-0 bg-white dark:bg-stone-950 border-b border-stone-200 dark:border-stone-800 z-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-4 flex flex-col gap-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`text-base no-underline ${
            currentPath.startsWith(link.href)
              ? 'text-stone-900 dark:text-stone-100 font-medium'
              : 'text-stone-500 dark:text-stone-400'
          }`}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script is:inline>
  (function() {
    function getState() {
      const stored = localStorage.getItem('theme');
      if (stored === 'light') return 'light';
      if (stored === 'dark') return 'dark';
      return 'system';
    }

    function showIcons(state) {
      const pairs = [
        ['icon-light', 'icon-light-mobile'],
        ['icon-dark', 'icon-dark-mobile'],
        ['icon-system', 'icon-system-mobile'],
      ];
      const names = { light: 0, dark: 1, system: 2 };
      const active = names[state];
      pairs.forEach(function(pair, i) {
        pair.forEach(function(id) {
          const el = document.getElementById(id);
          if (el) el.classList.toggle('hidden', i !== active);
        });
      });
    }

    function applyTheme(state) {
      const html = document.documentElement;
      html.classList.add('theme-transition');
      setTimeout(function() { html.classList.remove('theme-transition'); }, 300);
      if (state === 'dark') {
        html.classList.add('dark');
      } else if (state === 'light') {
        html.classList.remove('dark');
      } else {
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          html.classList.add('dark');
        } else {
          html.classList.remove('dark');
        }
      }
    }

    function nextState(current) {
      if (current === 'light') return 'dark';
      if (current === 'dark') return 'system';
      return 'light';
    }

    function handleToggle() {
      const current = getState();
      const next = nextState(current);
      if (next === 'system') {
        localStorage.removeItem('theme');
      } else {
        localStorage.setItem('theme', next);
      }
      applyTheme(next);
      showIcons(next);
    }

    showIcons(getState());

    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function() {
      if (getState() === 'system') applyTheme('system');
    });

    const btn = document.getElementById('theme-toggle');
    if (btn) btn.addEventListener('click', handleToggle);

    const btnMobile = document.getElementById('theme-toggle-mobile');
    if (btnMobile) btnMobile.addEventListener('click', handleToggle);

    const menuToggle = document.getElementById('mobile-menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    if (menuToggle && mobileMenu) {
      menuToggle.addEventListener('click', function() {
        mobileMenu.classList.toggle('hidden');
      });
    }
  })();
</script>
