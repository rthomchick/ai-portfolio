---
---

<button
  id="theme-toggle"
  aria-label="Toggle theme"
  class="text-stone-500 dark:text-stone-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-600 dark:focus-visible:ring-teal-400 rounded-sm"
>
  <!-- Sun icon (light mode active) -->
  <svg id="icon-light" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
    <circle cx="12" cy="12" r="4"/>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
  </svg>
  <!-- Moon icon (dark mode active) -->
  <svg id="icon-dark" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
  </svg>
  <!-- Monitor icon (system preference active) -->
  <svg id="icon-system" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
    <rect width="20" height="14" x="2" y="3" rx="2"/>
    <path d="M8 21h8M12 17v4"/>
  </svg>
</button>

<script is:inline>
  (function() {
    const btn = document.getElementById('theme-toggle');
    const iconLight = document.getElementById('icon-light');
    const iconDark = document.getElementById('icon-dark');
    const iconSystem = document.getElementById('icon-system');

    function getState() {
      const stored = localStorage.getItem('theme');
      if (stored === 'light') return 'light';
      if (stored === 'dark') return 'dark';
      return 'system';
    }

    function showIcon(state) {
      iconLight.classList.toggle('hidden', state !== 'light');
      iconDark.classList.toggle('hidden', state !== 'dark');
      iconSystem.classList.toggle('hidden', state !== 'system');
    }

    function applyTheme(state) {
      const html = document.documentElement;
      html.classList.add('theme-transition');
      setTimeout(function() { html.classList.remove('theme-transition'); }, 300);

      if (state === 'dark') {
        html.classList.add('dark');
      } else if (state === 'light') {
        html.classList.remove('dark');
      } else {
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          html.classList.add('dark');
        } else {
          html.classList.remove('dark');
        }
      }
    }

    function nextState(current) {
      if (current === 'light') return 'dark';
      if (current === 'dark') return 'system';
      return 'light';
    }

    showIcon(getState());

    btn.addEventListener('click', function() {
      const current = getState();
      const next = nextState(current);

      if (next === 'system') {
        localStorage.removeItem('theme');
      } else {
        localStorage.setItem('theme', next);
      }

      applyTheme(next);
      showIcon(next);
    });
  })();
</script>
