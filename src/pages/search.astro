---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Search" description="Search journal entries and project pages.">
  <Header />
  <main id="main-content" class="flex-1 max-w-5xl mx-auto px-4 sm:px-6 py-12 w-full">

    <h1 class="text-2xl font-medium tracking-tight text-stone-900 dark:text-stone-100 mb-6">Search</h1>

    <!-- Search bar -->
    <form id="search-form" class="relative mb-6" autocomplete="off">
      <label for="search-input" class="sr-only">Search journal entries and projects</label>
      <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-stone-400 pointer-events-none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
      </svg>
      <input
        id="search-input"
        type="search"
        name="q"
        placeholder="Search journal entries and projects..."
        autofocus
        class="w-full pl-11 pr-4 py-3 rounded-lg border border-stone-200 dark:border-stone-700 bg-white dark:bg-stone-900 text-stone-900 dark:text-stone-100 text-sm focus:outline-none focus:border-teal-600 dark:focus:border-teal-400 focus:ring-2 focus:ring-teal-600/25 dark:focus:ring-teal-400/25 transition-colors"
      />
    </form>

    <!-- Filter pills -->
    <div class="flex gap-2 mb-8" id="filter-pills">
      <button data-filter="all" aria-pressed="true" class="filter-pill active px-4 py-1.5 text-sm rounded-full border transition-colors">All</button>
      <button data-filter="journal" aria-pressed="false" class="filter-pill px-4 py-1.5 text-sm rounded-full border transition-colors">Journal</button>
      <button data-filter="project" aria-pressed="false" class="filter-pill px-4 py-1.5 text-sm rounded-full border transition-colors">Projects</button>
    </div>

    <!-- AI answer card (hidden until streaming begins) -->
    <div id="ai-card" class="hidden mb-8 rounded-xl border border-teal-200 dark:border-teal-900 bg-teal-50/50 dark:bg-teal-950/30 p-5 opacity-0 transition-opacity duration-300">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-teal-100 dark:bg-teal-900 text-teal-700 dark:text-teal-300">AI answer</span>
        <span class="text-xs text-stone-400 dark:text-stone-500">from your portfolio</span>
      </div>
      <div id="ai-answer-text" class="text-sm leading-relaxed text-stone-700 dark:text-stone-300 whitespace-pre-wrap" aria-live="polite" aria-atomic="false"></div>
      <div id="ai-sources" class="mt-4 flex flex-wrap gap-2 hidden"></div>
    </div>

    <!-- Screen reader announcements for search results -->
    <div id="search-status" role="status" aria-live="polite" aria-atomic="true" class="sr-only"></div>

    <!-- Result list -->
    <div id="result-list"></div>

    <!-- Empty state -->
    <div id="empty-state" class="hidden text-sm text-stone-400 dark:text-stone-500 py-8 text-center">No results found for this query.</div>

  </main>
  <Footer />

  <style>
    .filter-pill.active {
      background-color: #0F766E;
      color: white;
      border-color: #0F766E;
    }
    .dark .filter-pill.active {
      background-color: #2DD4BF;
      color: #1C1917;
      border-color: #2DD4BF;
    }
    .filter-pill:not(.active) {
      background-color: transparent;
      color: #78716C;
      border-color: #E7E5E4;
    }
    .dark .filter-pill:not(.active) {
      color: #A8A29E;
      border-color: #292524;
    }
    .filter-pill:not(.active):hover {
      border-color: #0D9488;
      color: #0D9488;
    }
    .dark .filter-pill:not(.active):hover {
      border-color: #2DD4BF;
      color: #2DD4BF;
    }
    :global(mark) {
      background-color: rgba(20, 184, 166, 0.25);
      color: inherit;
      border-radius: 3px;
    }
  </style>

  <script is:inline>
    (function () {
      var keywordResults = [];
      var semanticResults = [];
      var mergedResults = [];
      var aiAnswer = '';
      var aiSources = [];
      var activeFilter = 'all';
      var currentReader = null;

      var searchInput = document.getElementById('search-input');
      var searchForm = document.getElementById('search-form');
      var aiCard = document.getElementById('ai-card');
      var aiAnswerText = document.getElementById('ai-answer-text');
      var aiSourcesEl = document.getElementById('ai-sources');
      var resultList = document.getElementById('result-list');
      var emptyState = document.getElementById('empty-state');
      var searchStatus = document.getElementById('search-status');
      var filterPills = document.querySelectorAll('.filter-pill');

      // Filter pills
      filterPills.forEach(function (pill) {
        pill.addEventListener('click', function () {
          activeFilter = pill.dataset.filter;
          filterPills.forEach(function (p) {
            p.classList.remove('active');
            p.setAttribute('aria-pressed', 'false');
          });
          pill.classList.add('active');
          pill.setAttribute('aria-pressed', 'true');
          renderResultList();
        });
      });

      // Pre-populate from ?q= param
      var params = new URLSearchParams(window.location.search);
      var initialQuery = params.get('q');
      if (initialQuery) {
        searchInput.value = initialQuery;
        runSearch(initialQuery);
      }

      // Form submit
      searchForm.addEventListener('submit', function (e) {
        e.preventDefault();
        var query = searchInput.value.trim();
        if (!query) return;
        var url = new URL(window.location.href);
        url.searchParams.set('q', query);
        window.history.replaceState({}, '', url.toString());
        runSearch(query);
      });

      function resetState() {
        keywordResults = [];
        semanticResults = [];
        mergedResults = [];
        aiAnswer = '';
        aiSources = [];
        aiCard.classList.add('hidden');
        aiCard.style.opacity = '0';
        aiAnswerText.textContent = '';
        aiSourcesEl.innerHTML = '';
        aiSourcesEl.classList.add('hidden');
        resultList.innerHTML = '';
        emptyState.classList.add('hidden');
        if (currentReader) {
          try { currentReader.cancel(); } catch (e) {}
          currentReader = null;
        }
      }

      function weekFromUrl(url) {
        var m = (url || '').match(/\/journal\/week-(\d+)/);
        return m ? parseInt(m[1], 10) : null;
      }

      function normalizeUrl(url) {
        return (url || '').replace(/\/$/, '');
      }

      function mergeResults() {
        var byUrl = {};
        keywordResults.forEach(function (r) {
          byUrl[normalizeUrl(r.url)] = Object.assign({}, r, { matchType: 'keyword' });
        });
        semanticResults.forEach(function (r) {
          var key = normalizeUrl(r.url);
          if (byUrl[key]) {
            byUrl[key].matchType = 'both';
          } else {
            byUrl[key] = Object.assign({}, r, { matchType: 'semantic' });
          }
        });
        mergedResults = Object.values(byUrl);
      }

      function renderResultList() {
        var filtered = mergedResults.filter(function (r) {
          if (activeFilter === 'all') return true;
          return r.type === activeFilter;
        });

        if (filtered.length === 0 && mergedResults.length > 0) {
          resultList.innerHTML = '<p class="text-sm text-stone-400 dark:text-stone-500 py-4">No ' + activeFilter + ' results.</p>';
          emptyState.classList.add('hidden');
          if (searchStatus) searchStatus.textContent = 'No ' + activeFilter + ' results.';
          return;
        }

        if (filtered.length === 0) {
          resultList.innerHTML = '';
          // Don't show empty state while search is still running
          return;
        }

        emptyState.classList.add('hidden');
        if (searchStatus) {
          searchStatus.textContent = filtered.length === 1
            ? '1 result found.'
            : filtered.length + ' results found.';
        }
        var html = '';
        filtered.forEach(function (r) {
          var typeBadgeClass = r.type === 'journal'
            ? 'bg-stone-100 dark:bg-stone-800 text-stone-500 dark:text-stone-400'
            : 'bg-stone-100 dark:bg-stone-800 text-stone-500 dark:text-stone-400';
          var typeLabel = r.type === 'journal'
            ? ('Journal' + (r.week ? ' · Week ' + r.week : ''))
            : 'Project';

          var matchBadgeClass = (r.matchType === 'keyword')
            ? 'bg-emerald-50 dark:bg-emerald-950 text-emerald-600 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-800'
            : 'bg-blue-50 dark:bg-blue-950 text-blue-600 dark:text-blue-400 border border-blue-200 dark:border-blue-800';
          var matchLabel = (r.matchType === 'keyword') ? 'keyword' : 'semantic';

          // Keyword excerpts have Pagefind's <mark> HTML; semantic excerpts are plain text
          var excerptHtml = r.excerptHtml
            ? r.excerptHtml
            : escHtml((r.excerpt || '').substring(0, 220) + ((r.excerpt || '').length > 220 ? '…' : ''));

          html += '<div class="border-t border-stone-100 dark:border-stone-800 py-4">';
          html += '  <div class="flex items-start justify-between gap-4 mb-1">';
          html += '    <span class="text-xs px-2 py-0.5 rounded ' + typeBadgeClass + '">' + typeLabel + '</span>';
          html += '    <span class="text-xs px-2 py-0.5 rounded ' + matchBadgeClass + ' shrink-0">' + matchLabel + '</span>';
          html += '  </div>';
          html += '  <a href="' + escHtml(normalizeUrl(r.url)) + '" class="text-base font-medium text-stone-900 dark:text-stone-100 hover:text-teal-600 dark:hover:text-teal-400 transition-colors block mt-1">' + escHtml(r.title || 'Untitled') + '</a>';
          if (excerptHtml) {
            html += '  <p class="text-sm text-stone-500 dark:text-stone-400 leading-relaxed mt-1">' + excerptHtml + '</p>';
          }
          html += '</div>';
        });
        resultList.innerHTML = html;
      }

      function showAiCard() {
        if (aiCard.classList.contains('hidden')) {
          aiCard.classList.remove('hidden');
          requestAnimationFrame(function () {
            aiCard.style.opacity = '1';
          });
        }
      }

      function renderAiSources() {
        if (!aiSources || aiSources.length === 0) return;
        var html = '';
        aiSources.forEach(function (s) {
          var label = s.type === 'journal' ? 'Week ' + s.week : 'Project';
          html += '<a href="' + escHtml(s.url) + '" class="inline-flex items-center gap-1 text-xs px-2.5 py-1 rounded-full bg-white dark:bg-stone-900 border border-stone-200 dark:border-stone-700 text-stone-600 dark:text-stone-300 hover:border-teal-500 dark:hover:border-teal-500 transition-colors">';
          html += escHtml(label) + (s.title ? ' · ' + escHtml(s.title) : '');
          html += '</a>';
        });
        aiSourcesEl.innerHTML = html;
        aiSourcesEl.classList.remove('hidden');
      }

      function escHtml(str) {
        return String(str || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');
      }

      async function runPagefind(query) {
        try {
          var pagefind = await import('/pagefind/pagefind.js');
          var pfResults = await pagefind.search(query);
          var results = [];
          for (var i = 0; i < Math.min(pfResults.results.length, 10); i++) {
            var data = await pfResults.results[i].data();
            var type = (data.filters && data.filters.type && data.filters.type[0]) || (data.url.includes('/journal/') ? 'journal' : 'project');
            var week = weekFromUrl(data.url);
            results.push({
              url: data.url,
              title: data.meta && data.meta.title ? data.meta.title : data.title,
              excerpt: data.excerpt,
              excerptHtml: data.excerpt, // Pagefind excerpt already contains <mark> HTML
              type: type,
              week: week,
              matchType: 'keyword',
            });
          }
          keywordResults = results;
          mergeResults();
          renderResultList();
        } catch (e) {
          console.error('Pagefind error:', e);
        }
      }

      async function runSseStream(query) {
        try {
          var response = await fetch('/api/search', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ query: query, context: 'site' }),
          });

          if (!response.ok || !response.body) {
            console.error('SSE stream failed:', response.status);
            return;
          }

          var reader = response.body.getReader();
          currentReader = reader;
          var decoder = new TextDecoder();
          var buffer = '';

          while (true) {
            var chunk;
            try {
              chunk = await reader.read();
            } catch (e) {
              break;
            }
            if (chunk.done) break;

            buffer += decoder.decode(chunk.value, { stream: true });

            // Split on double newline (SSE event boundary)
            var events = buffer.split('\n\n');
            buffer = events.pop() || '';

            for (var i = 0; i < events.length; i++) {
              var block = events[i];
              var eventType = '';
              var eventData = '';
              var lines = block.split('\n');
              for (var j = 0; j < lines.length; j++) {
                var line = lines[j];
                if (line.startsWith('event: ')) {
                  eventType = line.slice(7).trim();
                } else if (line.startsWith('data: ')) {
                  eventData = line.slice(6);
                }
              }
              if (!eventType) continue;

              if (eventType === 'semantic') {
                try {
                  var matches = JSON.parse(eventData);
                  aiSources = matches;
                  semanticResults = matches.map(function (m) {
                    return {
                      url: m.url,
                      title: m.title,
                      excerpt: m.excerpt,
                      type: m.type,
                      week: m.week,
                      matchType: 'semantic',
                    };
                  });
                  mergeResults();
                  renderResultList();
                } catch (e) {
                  console.error('Failed to parse semantic results:', e);
                }
              } else if (eventType === 'ai-chunk') {
                try {
                  var token = JSON.parse(eventData);
                  aiAnswer += token;
                  showAiCard();
                  aiAnswerText.textContent = aiAnswer;
                } catch (e) {
                  aiAnswer += eventData;
                  showAiCard();
                  aiAnswerText.textContent = aiAnswer;
                }
              } else if (eventType === 'ai-done') {
                renderAiSources();
              } else if (eventType === 'done') {
                reader.cancel();
                currentReader = null;
                // Show empty state if truly no results
                if (mergedResults.length === 0) {
                  emptyState.classList.remove('hidden');
                }
                return;
              } else if (eventType === 'error') {
                console.error('SSE error event:', eventData);
              }
            }
          }
        } catch (e) {
          console.error('SSE stream error:', e);
        }
      }

      async function runSearch(query) {
        resetState();
        if (!query) return;
        // Run Pagefind and SSE stream in parallel
        await Promise.all([
          runPagefind(query),
          runSseStream(query),
        ]);
      }
    })();
  </script>
</BaseLayout>
