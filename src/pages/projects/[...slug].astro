---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContentActions from '../../components/ContentActions.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const allProjectSummaries = import.meta.glob<{ default: object }>('../../data/summaries/projects/*.json', { eager: true });
const projectSummaryModule = allProjectSummaries[`../../data/summaries/projects/${project.id}.json`];
const projectSummary = projectSummaryModule?.default ?? null;

const allProjectQuestions = import.meta.glob<{ default: object }>(
  '../../data/questions/projects/*.json', { eager: true }
);
const projectQuestionsModule = allProjectQuestions[`../../data/questions/projects/${project.id}.json`];
const projectQuestions = (projectQuestionsModule?.default as any)?.questions ?? null;

const badgeClasses: Record<string, string> = {
  deployed: 'bg-teal-50 text-teal-600 dark:bg-teal-950 dark:text-teal-400',
  built: 'bg-stone-100 text-stone-500 dark:bg-stone-800 dark:text-stone-400',
  planning: 'bg-stone-50 text-stone-400 dark:bg-stone-800 dark:text-stone-500',
};
const badgeLabel: Record<string, string> = {
  deployed: 'live',
  built: 'built',
  planning: 'planning',
};
---

<BaseLayout
  title={project.data.title}
  description={project.data.description}
>
  <Header />
  <main data-pagefind-body class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <meta data-pagefind-meta="description" content={project.data.description} />
    <meta data-pagefind-filter="type" content="project" />
    <a href="/projects" class="text-sm text-teal-600 dark:text-teal-400 link-slide transition-colors no-underline mb-8 inline-block">← Projects</a>

    <div class="reveal">
      <div class="flex items-center gap-3 mb-4">
        <h1 data-pagefind-meta="title" class="text-3xl font-medium tracking-tight text-stone-900 dark:text-stone-100">{project.data.title}</h1>
        <span class={`text-xs px-2.5 py-1 rounded-full font-medium ${badgeClasses[project.data.status]}`}>
          {badgeLabel[project.data.status]}
        </span>
      </div>

      <p class="text-base text-stone-500 dark:text-stone-400 leading-relaxed max-w-2xl mb-6">{project.data.description}</p>

      <ContentActions
        slug={project.id}
        summary={projectSummary as any}
        questions={projectQuestions}
        pageType="project"
        showListen={false}
      />

      <!-- Details section -->
      <div class="bg-stone-50 dark:bg-stone-900 rounded-lg p-6 mb-10 max-w-2xl">
      <dl class="flex flex-col gap-4">
        <div>
          <dt class="text-xs uppercase tracking-wider text-stone-400 dark:text-stone-500 mb-1">Problem solved</dt>
          <dd class="text-sm text-stone-700 dark:text-stone-300 leading-relaxed">{project.data.problemSolved}</dd>
        </div>

        {project.data.architecturePattern && (
          <div>
            <dt class="text-xs uppercase tracking-wider text-stone-400 dark:text-stone-500 mb-1">Architecture</dt>
            <dd class="text-sm text-stone-700 dark:text-stone-300">{project.data.architecturePattern}</dd>
          </div>
        )}

        <div>
          <dt class="text-xs uppercase tracking-wider text-stone-400 dark:text-stone-500 mb-2">Tech stack</dt>
          <dd data-pagefind-ignore class="flex flex-wrap gap-1.5">
            {project.data.techStack.map(tech => (
              <span class="text-xs bg-white dark:bg-stone-800 border border-stone-200 dark:border-stone-700 text-stone-600 dark:text-stone-300 px-2.5 py-1 rounded-full">{tech}</span>
            ))}
          </dd>
        </div>

        <div>
          <dt class="text-xs uppercase tracking-wider text-stone-400 dark:text-stone-500 mb-1">Week built</dt>
          <dd>
            <a
              href={project.data.journalSlug ? `/journal/${project.data.journalSlug}` : `/journal`}
              class="text-sm text-teal-600 dark:text-teal-400 hover:underline"
            >Week {project.data.weekBuilt}</a>
          </dd>
        </div>

        {(project.data.deployUrl || project.data.repoUrl) && (
          <div>
            <dt class="text-xs uppercase tracking-wider text-stone-400 dark:text-stone-500 mb-2">Links</dt>
            <dd class="flex flex-wrap gap-4">
              {project.data.deployUrl && (
                <a href={project.data.deployUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-teal-600 dark:text-teal-400 hover:underline">
                  Live app ↗
                </a>
              )}
              {project.data.repoUrl && (
                <a href={project.data.repoUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-teal-600 dark:text-teal-400 hover:underline">
                  GitHub ↗
                </a>
              )}
            </dd>
          </div>
        )}
      </dl>
      </div>
    </div>

    <!-- Body -->
    <div class="prose prose-stone max-w-2xl prose-headings:font-medium prose-headings:tracking-tight prose-a:text-teal-600 prose-a:no-underline hover:prose-a:underline dark:prose-invert reveal">
      <Content />
    </div>
  </main>
  <Footer />
</BaseLayout>
