---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroPlaceholder from '../components/HeroPlaceholder.astro';
import FeaturedEntry from '../components/FeaturedEntry.astro';
import JournalCard from '../components/JournalCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allJournalEntries = await getCollection('journal', ({ data }) => data.status === 'published');
const sortedEntries = allJournalEntries.sort((a, b) => b.data.week - a.data.week);

const featured = sortedEntries[0];
const recentEntries = sortedEntries.slice(1, 4);

function calcReadingTime(body: string | undefined): number {
  if (!body) return 0;
  const textOnly = body.replace(/```[\s\S]*?```/g, '').replace(/`[^`]*`/g, '');
  const wordCount = textOnly.trim().split(/\s+/).filter(Boolean).length;
  return wordCount > 0 ? Math.max(1, Math.ceil(wordCount / 200)) : 0;
}

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => a.data.sortOrder - b.data.sortOrder).slice(0, 3);

---

<BaseLayout
  title="Richard Thomchick"
  description="Senior product manager documenting a 6-month journey from zero AI experience to shipping production-grade tools. Weekly journal and live demos."
>
  <Header />
  <main id="main-content" class="max-w-5xl mx-auto px-4 sm:px-6">
    <HeroPlaceholder />

    {featured && (
      <FeaturedEntry
        headline={featured.data.headline}
        summary={featured.data.summary}
        slug={featured.id}
        date={featured.data.date}
        readingTime={calcReadingTime(featured.body)}
      />
    )}

    <hr class="border-stone-200 dark:border-stone-800" />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 py-12 stagger">
      <!-- Journal column -->
      <div>
        <h2 class="text-xs uppercase tracking-wider text-stone-400 dark:text-stone-500 mb-6">Journal</h2>
        <div class="divide-y divide-stone-200 dark:divide-stone-800 [&>article:first-child]:pt-0">
          {recentEntries.map(entry => (
            <JournalCard
              headline={entry.data.headline}
              summary={entry.data.summary}
              date={entry.data.date}
              slug={entry.id}
              tags={entry.data.tags}
              compact
              readingTime={calcReadingTime(entry.body)}
            />
          ))}
        </div>
        <div class="mt-6">
          <a href="/journal" class="text-sm text-teal-700 dark:text-teal-400 link-slide font-medium">All entries →</a>
        </div>
      </div>

      <!-- Projects column -->
      <div>
        <h2 class="text-xs uppercase tracking-wider text-stone-400 dark:text-stone-500 mb-6">Shipped</h2>
        <div class="flex flex-col gap-6">
          {sortedProjects.map(project => (
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              status={project.data.status}
              slug={project.id}
            />
          ))}
        </div>
        <div class="mt-6">
          <a href="/projects" class="text-sm text-teal-700 dark:text-teal-400 link-slide font-medium">All projects →</a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
