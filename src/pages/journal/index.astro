---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import JournalCard from '../../components/JournalCard.astro';
import { getCollection } from 'astro:content';

const allEntries = await getCollection('journal', ({ data }) => data.status === 'published');
const sorted = allEntries.sort((a, b) => b.data.week - a.data.week);

function calcReadingTime(body: string | undefined): number {
  if (!body) return 0;
  const textOnly = body.replace(/```[\s\S]*?```/g, '').replace(/`[^`]*`/g, '');
  const wordCount = textOnly.trim().split(/\s+/).filter(Boolean).length;
  return wordCount > 0 ? Math.max(1, Math.ceil(wordCount / 200)) : 0;
}
---

<BaseLayout
  title="Journal"
  description="Weekly learning journal documenting hands-on AI product development — from API basics through multi-agent systems, RAG, evaluation, and responsible AI."
>
  <Header />
  <main class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <h1 class="text-3xl font-medium tracking-tight text-stone-900 dark:text-stone-100 mb-3">Journal</h1>
    <p class="text-base text-stone-500 dark:text-stone-400 leading-relaxed mb-12">Weekly entries from a six-month AI product development program.</p>

    <div class="divide-y divide-stone-200 dark:divide-stone-800">
      {sorted.map(entry => (
        <JournalCard
          headline={entry.data.headline}
          summary={entry.data.summary}
          date={entry.data.date}
          slug={entry.id}
          tags={entry.data.tags}
          readingTime={calcReadingTime(entry.body)}
        />
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>
