---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const { title = 'Richard Thomchick', description = 'AI product development portfolio and learning journal.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title === 'Richard Thomchick' ? title : `${title} — Richard Thomchick`}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,400&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-white text-stone-900 font-sans antialiased">
    <slot />
  </body>
</html>
